      "component": "components/brand-story.twig"
    },
    {
      "id": "testimonials",
      "name": "Testimonials",
      "component": "components/testimonials.twig"
    },
    {
      "id": "newsletter",
      "name": "Newsletter",
      "component": "components/newsletter.twig"
    },
    {
      "id": "whatsapp_banner",
      "name": "WhatsApp CTA",
      "component": "components/whatsapp-banner.twig"
