<!DOCTYPE html>
<html lang="{{ language.code }}" dir="{{ theme.is_rtl ? 'rtl' : 'ltr' }}">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page.title | default(store.name) }}</title>
    <meta name="description" content="{{ page.description | default(store.description) }}">
    <link rel="icon" type="image/png" href="{{ store.icon }}">

    {% hook 'head:start' %}
    {% hook head %}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="{{ 'app.css' | asset }}">

    {% block head %}{% endblock %}
    {% hook 'head:end' %}
</head>
<body class="font-arabic bg-white antialiased overflow-x-hidden">
    {% hook 'body:start' %}

    {% include 'components/header.twig' %}

    <main id="main-content" role="main">
        {% block content %}{% endblock %}
    </main>

    {% include 'components/footer.twig' %}
    {% include 'components/whatsapp.twig' %}

    <button id="back-to-top"
            style="display:none;"
            class="fixed bottom-24 end-6 z-50 w-11 h-11 rounded-full bg-gold text-black flex items-center justify-center hover:bg-gold-dark shadow-lg transition-all">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
        </svg>
    </button>

    <salla-cart-summary></salla-cart-summary>

    <script src="{{ 'app.js' | asset }}"></script>
    {% block scripts %}{% endblock %}
    {% hook 'body:end' %}
</body>
</html>
