<!DOCTYPE html>
<html lang="{{ store.language_code|default('ar') }}" dir="{{ store.direction|default('rtl') }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}{{ page.title|default(store.name) }} | {{ store.name }}{% endblock %}</title>
  <meta name="description" content="{% block description %}{{ page.description|default(store.description) }}{% endblock %}" />
  <link rel="canonical" href="{{ store.url }}" />

  {# Open Graph #}
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="{{ store.name }}" />
  <meta property="og:title" content="{{ page.title|default(store.name) }}" />
  <meta property="og:description" content="{{ page.description|default(store.description) }}" />
  <meta property="og:image" content="{% block og_image %}{{ store.logo }}{% endblock %}" />
  <meta property="og:url" content="{{ store.url }}" />

  {# Favicon #}
  <link rel="icon" type="image/png" href="{{ store.logo }}" />

  {# Google Fonts: Tajawal + Cormorant Garamond #}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

  {# Tailwind compiled CSS #}
  <link rel="stylesheet" href="{{ 'dist/css/app.css' | asset_url }}" />

  {# Salla Web Components #}
  <script type="module" src="https://cdn.salla.network/js/twilight-components.js"></script>

  {% block head %}{% endblock %}
  {% hook 'head:end' %}
</head>

<body class="bg-white text-gray-900 font-sans antialiased overflow-x-hidden" style="font-family: 'Tajawal', sans-serif;">

  {% hook 'body:start' %}

  {# Announcement bar #}
  {% include 'components/announcement-bar.twig' %}

  {# Header #}
  {% include 'components/header.twig' %}

  {# Page content #}
  <main id="main-content">
    {% block content %}{% endblock %}
  </main>

  {# Footer #}
  {% include 'components/footer.twig' %}

  {# Floating WhatsApp #}
  {% include 'components/whatsapp.twig' %}

  {# Back to top #}
  <button id="back-to-top"
          aria-label="{{ trans('general.back_to_top') }}"
          class="fixed bottom-24 end-6 z-50 w-11 h-11 rounded-full bg-gold text-black flex items-center justify-center opacity-0 invisible transition-all duration-300 hover:bg-gold-dark shadow-gold">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
    </svg>
  </button>

  {# Salla cart drawer #}
  <salla-cart-summary></salla-cart-summary>

  {# Custom JS #}
  <script src="{{ 'src/assets/js/app.js' | asset_url }}"></script>

  {% block scripts %}{% endblock %}
  {% hook 'body:end' %}
</body>
</html>
