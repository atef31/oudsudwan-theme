<!DOCTYPE html>
<html lang="{{ store.language_code|default('ar') }}" dir="{{ store.direction|default('rtl') }}" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
  <title>{% block title %}{{ page.title|default(store.name) }} | {{ store.name }}{% endblock %}</title>
  <meta name="description" content="{% block description %}{{ page.description|default('زيوت العود الفيتنامي الفاخرة — شرائح عود، بخور، ومنتجات عود أصيلة.') }}{% endblock %}" />
  <link rel="canonical" href="{{ store.url }}" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="{{ store.name }}" />
  <meta property="og:title" content="{% block og_title %}{{ page.title|default(store.name) }}{% endblock %}" />
  <meta property="og:description" content="{% block og_description %}{{ page.description|default('') }}{% endblock %}" />
  <meta property="og:image" content="{% block og_image %}{{ store.logo }}{% endblock %}" />
  <meta property="og:url" content="{{ store.url }}" />
  <link rel="icon" type="image/png" href="{{ settings.favicon|default(store.logo) }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{ 'dist/css/app.css' | asset_url }}" />
  <script type="module" src="https://unpkg.com/@salla.sa/twilight-components/dist/twilight-components.esm.js"></script>
  {% block head %}{% endblock %}
</head>
<body class="bg-brand-black text-white font-tajawal antialiased overflow-x-hidden">

  {# Gold announcement bar — shown above the full header stack #}
  {% if settings.show_announcement_bar != false %}{% include 'components/announcement-bar.twig' %}{% endif %}
  {# Two-tier header: top contact bar + main navbar #}
  {% include 'components/header.twig' %}

  <main id="main-content" class="min-h-screen">
    {% block content %}{% endblock %}
  </main>

  {% include 'components/footer.twig' %}
  {% include 'components/whatsapp.twig' %}

  <button id="back-to-top" aria-label="العودة للأعلى"
    class="fixed bottom-24 end-6 z-80 w-10 h-10 rounded-full bg-brand-gray border border-gold/30 text-gold flex items-center justify-center opacity-0 invisible transition-all duration-300 hover:bg-gold hover:text-black">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
    </svg>
  </button>

  <salla-cart-summary></salla-cart-summary>
  <script src="{{ 'src/assets/js/app.js' | asset_url }}"></script>
  {% block scripts %}{% endblock %}
</body>
</html>
