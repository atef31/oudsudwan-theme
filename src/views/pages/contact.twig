{% extends 'layouts/master.twig' %}
{% block title %}{{ trans('general.contact') }} | {{ store.name }}{% endblock %}

{% block content %}
<section class="py-16 bg-white text-center border-b border-gray-100" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-xl mx-auto px-4">
    <p class="text-gold text-sm tracking-[0.25em] uppercase mb-3" style="font-family: 'Cormorant Garamond', serif;">Contact Us</p>
    <h1 class="text-2xl lg:text-4xl font-black text-gray-900 mb-3">{{ trans('general.contact') }}</h1>
    <div class="w-12 h-0.5 bg-gold mx-auto mb-4"></div>
    <p class="text-gray-500 text-sm">فريقنا جاهز للرد على استفساراتك خلال 24 ساعة</p>
  </div>
</section>

<section class="py-14" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <div class="space-y-4">
        <a href="https://wa.me/{{ theme.settings.get('whatsapp_number', '966XXXXXXXXX')|default('966XXXXXXXXX') }}" target="_blank" rel="noopener"
           class="flex items-center gap-4 bg-white border border-gray-100 hover:border-gold/40 rounded-2xl p-5 transition-all group">
          <div class="w-11 h-11 rounded-xl bg-green-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a8.073 8.073 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479s1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.861 9.861 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-0.5">{{ trans('general.whatsapp_support') }}</p>
            <p class="text-gray-900 font-semibold text-sm group-hover:text-gold transition-colors" dir="ltr">+{{ theme.settings.get('whatsapp_number', '966XXXXXXXXX')|default('966XXXXXXXXX') }}</p>
          </div>
        </a>

        <a href="mailto:{{ store.email|default('info@oudsudwan.com') }}"
           class="flex items-center gap-4 bg-white border border-gray-100 hover:border-gold/40 rounded-2xl p-5 transition-all group">
          <div class="w-11 h-11 rounded-xl bg-gold/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <p class="text-xs text-gray-400 mb-0.5">البريد الإلكتروني</p>
            <p class="text-gray-900 font-semibold text-sm group-hover:text-gold transition-colors">{{ store.email|default('info@oudsudwan.com') }}</p>
          </div>
        </a>

        <a href="https://wa.me/{{ theme.settings.get('whatsapp_number', '966XXXXXXXXX')|default('966XXXXXXXXX') }}" target="_blank" rel="noopener"
           class="flex items-center justify-center gap-2 w-full bg-green-500 hover:bg-green-400 text-white font-bold py-4 rounded-2xl transition-all">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a8.073 8.073 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479s1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.861 9.861 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          {{ trans('general.chat_now') }}
        </a>
      </div>

      <div class="lg:col-span-2 bg-white border border-gray-100 rounded-2xl p-7 lg:p-10">
        <h2 class="font-black text-gray-900 text-xl mb-6">أرسل لنا رسالة</h2>
        <salla-form action="{{ store.url }}/contact" method="POST" class="space-y-5 block">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-gray-600 text-sm mb-2">الاسم الكامل <span class="text-gold">*</span></label>
              <input type="text" name="name" required placeholder="محمد العتيبي"
                class="w-full border border-gray-200 focus:border-gold text-gray-900 text-sm rounded-xl px-4 py-3 outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-gray-600 text-sm mb-2">رقم الجوال</label>
              <input type="tel" name="phone" placeholder="+966 5X XXX XXXX"
                class="w-full border border-gray-200 focus:border-gold text-gray-900 text-sm rounded-xl px-4 py-3 outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-gray-600 text-sm mb-2">البريد الإلكتروني <span class="text-gold">*</span></label>
            <input type="email" name="email" required placeholder="example@email.com"
              class="w-full border border-gray-200 focus:border-gold text-gray-900 text-sm rounded-xl px-4 py-3 outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-gray-600 text-sm mb-2">الرسالة <span class="text-gold">*</span></label>
            <textarea name="message" rows="5" required placeholder="اكتب رسالتك هنا..."
              class="w-full border border-gray-200 focus:border-gold text-gray-900 text-sm rounded-xl px-4 py-3 outline-none transition-colors resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-gold hover:bg-gold-dark text-black font-bold py-4 rounded-xl transition-all duration-300 shadow-gold text-base">
            إرسال الرسالة
          </button>
        </salla-form>
      </div>
    </div>
  </div>
</section>
{% endblock %}
