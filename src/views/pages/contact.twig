{% extends 'layouts/master.twig' %}

{% block title %}{{ 'تواصل معنا' | trans }} | {{ store.name }}{% endblock %}
{% block description %}{{ 'تواصل مع فريق سدوان للعود — نحن هنا للإجابة على استفساراتك واستقبال طلباتك.' | trans }}{% endblock %}

{% block content %}

{# Hero #}
<section class="py-20 bg-black text-center relative overflow-hidden">
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 2px 2px, #C9A24A 1px, transparent 0); background-size: 30px 30px;"></div>
  <div class="relative z-10 max-w-screen-xl2 mx-auto px-4">
    <p class="font-cormorant text-gold/70 text-sm tracking-[0.4em] uppercase mb-4">Contact Us</p>
    <h1 class="font-tajawal font-black text-white mb-4" style="font-size: clamp(2rem, 4vw, 3.5rem);">{{ 'تواصل معنا' | trans }}</h1>
    <div class="w-16 h-0.5 bg-gold mx-auto mb-4"></div>
    <p class="text-ivory/60 text-sm max-w-md mx-auto">{{ 'فريقنا جاهز للرد على استفساراتك خلال 24 ساعة.' | trans }}</p>
  </div>
</section>

<section class="py-16 bg-brand-gray">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      {# Contact info cards #}
      <div class="space-y-5">
        {% for info in [
          { icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', title: 'واتساب', value: '+' ~ settings.whatsapp_number|default('966XXXXXXXXX'), href: 'https://wa.me/' ~ settings.whatsapp_number|default('966XXXXXXXXX') },
          { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'البريد الإلكتروني', value: store.email|default('info@oudsudwan.com'), href: 'mailto:' ~ store.email|default('info@oudsudwan.com') },
          { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'ساعات العمل', value: 'السبت – الخميس: 9ص – 10م', href: null }
        ] %}
          <div class="bg-black border border-gold/15 rounded-xl p-6 flex items-start gap-4">
            <div class="w-11 h-11 rounded-full bg-gold/10 border border-gold/25 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="{{ info.icon }}"/>
              </svg>
            </div>
            <div>
              <p class="text-gold text-xs font-medium tracking-widest uppercase mb-1">{{ info.title | trans }}</p>
              {% if info.href %}
                <a href="{{ info.href }}" class="text-ivory/80 hover:text-gold text-sm transition-colors">{{ info.value }}</a>
              {% else %}
                <p class="text-ivory/80 text-sm">{{ info.value | trans }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}

        {# WhatsApp quick CTA #}
        <a href="https://wa.me/{{ settings.whatsapp_number|default('966XXXXXXXXX') }}"
           target="_blank" rel="noopener noreferrer"
           class="flex items-center justify-center gap-3 bg-green-500/10 border border-green-500/30 hover:bg-green-500/20 text-green-400 rounded-xl p-5 transition-all duration-300">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <div>
            <p class="font-tajawal font-bold text-sm">{{ 'تحدث معنا الآن' | trans }}</p>
            <p class="text-green-400/60 text-xs">{{ 'رد سريع خلال دقائق' | trans }}</p>
          </div>
        </a>
      </div>

      {# Contact form #}
      <div class="lg:col-span-2">
        <div class="bg-black border border-gold/15 rounded-xl p-7 lg:p-10">
          <h2 class="font-tajawal font-bold text-white text-xl mb-6">{{ 'أرسل لنا رسالة' | trans }}</h2>

          <salla-form action="{{ store.url }}/contact" method="POST" class="space-y-5 block">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-ivory/70 text-sm mb-2">{{ 'الاسم الكامل' | trans }} <span class="text-gold">*</span></label>
                <input type="text" name="name" required
                  placeholder="{{ 'محمد العتيبي' | trans }}"
                  class="w-full bg-brand-gray border border-white/10 focus:border-gold text-ivory placeholder-ivory/30 text-sm rounded-lg px-4 py-3 outline-none transition-colors duration-200" />
              </div>
              <div>
                <label class="block text-ivory/70 text-sm mb-2">{{ 'رقم الجوال' | trans }}</label>
                <input type="tel" name="phone"
                  placeholder="+966 5X XXX XXXX"
                  class="w-full bg-brand-gray border border-white/10 focus:border-gold text-ivory placeholder-ivory/30 text-sm rounded-lg px-4 py-3 outline-none transition-colors duration-200" />
              </div>
            </div>

            <div>
              <label class="block text-ivory/70 text-sm mb-2">{{ 'البريد الإلكتروني' | trans }} <span class="text-gold">*</span></label>
              <input type="email" name="email" required
                placeholder="example@email.com"
                class="w-full bg-brand-gray border border-white/10 focus:border-gold text-ivory placeholder-ivory/30 text-sm rounded-lg px-4 py-3 outline-none transition-colors duration-200" />
            </div>

            <div>
              <label class="block text-ivory/70 text-sm mb-2">{{ 'موضوع الرسالة' | trans }}</label>
              <select name="subject"
                class="w-full bg-brand-gray border border-white/10 focus:border-gold text-ivory text-sm rounded-lg px-4 py-3 outline-none transition-colors duration-200 appearance-none">
                <option value="">{{ 'اختر الموضوع' | trans }}</option>
                <option>{{ 'استفسار عن منتج' | trans }}</option>
                <option>{{ 'طلب توصية شخصية' | trans }}</option>
                <option>{{ 'الشحن والتوصيل' | trans }}</option>
                <option>{{ 'الإرجاع والاستبدال' | trans }}</option>
                <option>{{ 'أخرى' | trans }}</option>
              </select>
            </div>

            <div>
              <label class="block text-ivory/70 text-sm mb-2">{{ 'الرسالة' | trans }} <span class="text-gold">*</span></label>
              <textarea name="message" rows="5" required
                placeholder="{{ 'اكتب رسالتك هنا...' | trans }}"
                class="w-full bg-brand-gray border border-white/10 focus:border-gold text-ivory placeholder-ivory/30 text-sm rounded-lg px-4 py-3 outline-none transition-colors duration-200 resize-none"></textarea>
            </div>

            <button type="submit"
              class="w-full bg-gold hover:bg-gold-light text-black font-tajawal font-bold py-4 rounded-lg transition-all duration-300 shadow-gold hover:shadow-gold-lg text-base">
              {{ 'إرسال الرسالة' | trans }}
            </button>
          </salla-form>
        </div>
      </div>
    </div>
  </div>
</section>

{% endblock %}
