{% extends 'layouts/master.twig' %}
{% block title %}{{ category.name|default(trans('general.products')) }} | {{ store.name }}{% endblock %}

{% block content %}
<section class="py-8 bg-gray-50 border-b border-gray-100" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6">
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-4">
      <a href="{{ store.url }}" class="hover:text-gold transition-colors">{{ trans('general.home') }}</a>
      <span>›</span>
      <span class="text-gray-900">{{ category.name|default(trans('general.products')) }}</span>
    </nav>
    <h1 class="text-2xl lg:text-3xl font-black text-gray-900">{{ category.name|default(trans('general.products')) }}</h1>
  </div>
</section>

<section class="py-10" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6">
    <div class="flex flex-col lg:flex-row gap-8">

      {# Sidebar #}
      <aside class="w-full lg:w-60 shrink-0">
        <div class="bg-white border border-gray-100 rounded-xl p-5 sticky top-24">
          <h2 class="font-bold text-gray-900 text-sm mb-4">{{ trans('general.categories') }}</h2>
          <ul class="space-y-2 list-none m-0 p-0">
            {% for item in [
              { l: trans('general.oud_oil'),   s: 'oud-oil' },
              { l: trans('general.oud_chips'), s: 'oud-chips' },
              { l: trans('general.incense'),   s: 'incense' },
              { l: trans('general.gift_sets'), s: 'gift-sets' }
            ] %}
              <li><a href="{{ store.url }}/categories/{{ item.s }}"
                class="flex items-center gap-2 text-sm py-1.5 {{ category.slug == item.s ? 'text-gold font-semibold' : 'text-gray-500 hover:text-gold' }} transition-colors">
                <span class="w-1.5 h-1.5 rounded-full {{ category.slug == item.s ? 'bg-gold' : 'bg-gray-300' }}"></span>
                {{ item.l }}
              </a></li>
            {% endfor %}
          </ul>
        </div>
      </aside>

      {# Products #}
      <main class="flex-1">
        <div class="flex items-center justify-between mb-6">
          <p class="text-gray-500 text-sm">{% if products is defined %}{{ products|length }} منتج{% endif %}</p>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
          {% if products is defined and products|length > 0 %}
            {% for product in products %}{% include 'components/product-card.twig' %}{% endfor %}
          {% else %}
            <div class="col-span-full text-center py-16 text-gray-400">
              <svg class="w-12 h-12 mx-auto mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
              لا توجد منتجات حالياً
            </div>
          {% endif %}
        </div>
        {% if pagination is defined %}
          <div class="mt-10 flex items-center justify-center gap-2">
            {% if pagination.prev %}<a href="{{ pagination.prev }}" class="px-4 py-2 border border-gray-200 rounded hover:border-gold text-sm transition-colors">{{ trans('general.home') }}</a>{% endif %}
            {% if pagination.next %}<a href="{{ pagination.next }}" class="px-4 py-2 border border-gold text-gold rounded hover:bg-gold hover:text-black text-sm transition-all">التالي</a>{% endif %}
          </div>
        {% endif %}
      </main>
    </div>
  </div>
</section>
{% endblock %}
