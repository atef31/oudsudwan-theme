{% extends 'layouts/master.twig' %}

{% block title %}{{ store.name }} — {{ trans('general.best_sellers') }}{% endblock %}

{% block content %}

  {% include 'components/announcement-bar.twig' %}
  {% include 'components/hero-slider.twig' %}

  {# Trust Strip #}
  <section class="trust-strip bg-black border-y border-gold/10 py-7">
    <div class="max-w-screen-xl mx-auto px-4 lg:px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-x-reverse divide-gold/10">
        {% for item in [
          { icon: 'M13 10V3L4 14h7v7l9-11h-7z',                                                                                           title: trans('general.fast_shipping'),     sub: trans('general.fast_shipping_sub') },
          { icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',                                                   title: trans('general.luxury_packaging'),  sub: trans('general.luxury_packaging_sub') },
          { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: trans('general.quality_guarantee'), sub: trans('general.quality_guarantee_sub') },
          { icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', title: trans('general.whatsapp_support'),  sub: trans('general.whatsapp_support_sub') }
        ] %}
          <div class="flex items-center gap-4 px-6 py-2">
            <div class="w-10 h-10 rounded-full bg-gold/10 border border-gold/20 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="{{ item.icon }}"/>
              </svg>
            </div>
            <div>
              <p class="text-ivory font-semibold text-sm">{{ item.title }}</p>
              <p class="text-ivory/50 text-xs mt-0.5">{{ item.sub }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {% include 'components/categories.twig' %}
  {% include 'components/featured-products.twig' %}
  {% include 'components/brand-story.twig' %}
  {% include 'components/testimonials.twig' %}
  {% include 'components/whatsapp-banner.twig' %}
  {% include 'components/newsletter.twig' %}

{% endblock %}
