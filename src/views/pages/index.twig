{% extends 'layouts/master.twig' %}

{% block content %}

    {# Announcement Bar — always shown above everything #}
    {% if theme.settings.get('show_announcement', true) %}
        {% include 'components/announcement-bar.twig' %}
    {% endif %}

    {# Salla page-builder renders all merchant-configured homepage sections #}
    {% component home %}

    {#
        Fallback sections shown when no sections are configured yet.
        Once the merchant adds sections via the theme editor, {% component home %}
        will render them instead and these won't show.
    #}
    {% if not home_components_count %}
        {% include 'components/hero-slider.twig' %}

        <section class="bg-black py-4">
            <div class="max-w-7xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-0">
                <div class="flex items-center gap-3 justify-center p-4 border-e border-gray-800">
                    <span class="text-2xl">🚚</span>
                    <div class="{{ theme.is_rtl ? 'text-right' : 'text-left' }}">
                        <p class="text-white text-sm font-medium">{{ trans('general.fast_shipping') }}</p>
                        <p class="text-gray-400 text-xs">{{ trans('general.fast_shipping_sub') }}</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 justify-center p-4 border-e border-gray-800">
                    <span class="text-2xl">📦</span>
                    <div class="{{ theme.is_rtl ? 'text-right' : 'text-left' }}">
                        <p class="text-white text-sm font-medium">{{ trans('general.luxury_packaging') }}</p>
                        <p class="text-gray-400 text-xs">{{ trans('general.luxury_packaging_sub') }}</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 justify-center p-4 border-e border-gray-800">
                    <span class="text-2xl">✅</span>
                    <div class="{{ theme.is_rtl ? 'text-right' : 'text-left' }}">
                        <p class="text-white text-sm font-medium">{{ trans('general.quality_guarantee') }}</p>
                        <p class="text-gray-400 text-xs">{{ trans('general.quality_guarantee_sub') }}</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 justify-center p-4">
                    <span class="text-2xl">💬</span>
                    <div class="{{ theme.is_rtl ? 'text-right' : 'text-left' }}">
                        <p class="text-white text-sm font-medium">{{ trans('general.whatsapp_support') }}</p>
                        <p class="text-gray-400 text-xs">{{ trans('general.whatsapp_support_sub') }}</p>
                    </div>
                </div>
            </div>
        </section>

        {% include 'components/categories.twig' %}
        {% include 'components/featured-products.twig' %}
        {% include 'components/brand-story.twig' %}
        {% include 'components/testimonials.twig' %}
        {% include 'components/whatsapp-banner.twig' %}
        {% include 'components/newsletter.twig' %}
    {% endif %}

{% endblock %}

{% block scripts %}
    <script defer src="{{ 'dist/js/app.js' | asset }}"></script>
{% endblock %}
