{% extends 'layouts/master.twig' %}

{% block title %}{{ store.name }} — {{ trans('general.best_sellers') }}{% endblock %}

{% block content %}

{# ── 1. Hero Slider ── #}
{% include 'components/hero-slider.twig' %}

{# ── 2. Trust Strip ── #}
<section class="py-8 bg-white border-b border-gray-100" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:divide-x lg:divide-x-reverse divide-gray-100">
      {% for item in [
        { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: trans('general.fast_shipping'), sub: trans('general.fast_shipping_sub') },
        { icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4', title: trans('general.luxury_packaging'), sub: trans('general.luxury_packaging_sub') },
        { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: trans('general.quality_guarantee'), sub: trans('general.quality_guarantee_sub') },
        { icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', title: trans('general.whatsapp_support'), sub: trans('general.whatsapp_support_sub') }
      ] %}
        <div class="flex items-center gap-4 px-4">
          <div class="w-11 h-11 rounded-full bg-gold/10 border border-gold/20 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="{{ item.icon }}"/></svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 text-sm">{{ item.title }}</p>
            <p class="text-gray-500 text-xs mt-0.5">{{ item.sub }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── 3. Categories Grid ── #}
{% include 'components/categories.twig' %}

{# ── 4. Featured Products ── #}
<section class="py-14 lg:py-20 bg-white" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-gold text-sm tracking-[0.25em] uppercase mb-2" style="font-family: 'Cormorant Garamond', serif;">OUDSUDWAN</p>
        <h2 class="text-2xl lg:text-3xl font-black text-gray-900">{{ trans('general.featured_title') }}</h2>
        <div class="w-10 h-0.5 bg-gold mt-3"></div>
      </div>
      <a href="{{ store.url }}/categories" class="hidden sm:flex items-center gap-1 text-gold hover:text-gold-dark text-sm font-medium transition-colors">
        {{ trans('general.view_all') }}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {% if store.products is defined and store.products|length > 0 %}
        {% for product in store.products|slice(0,8) %}
          {% include 'components/product-card.twig' %}
        {% endfor %}
      {% else %}
        {# Skeleton while loading #}
        {% for i in 1..8 %}
          <div class="bg-gray-100 rounded-xl overflow-hidden animate-pulse">
            <div class="aspect-square bg-gray-200"></div>
            <div class="p-4 space-y-3">
              <div class="h-3 bg-gray-200 rounded w-3/4"></div>
              <div class="h-3 bg-gray-200 rounded w-1/2"></div>
              <div class="h-8 bg-gray-200 rounded mt-3"></div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{# ── 5. Featured Product Banner ── #}
<section class="relative py-0 overflow-hidden" style="min-height: 420px; background: #0a0a0a;">
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 2px 2px, #C9A24A 1px, transparent 0); background-size: 28px 28px;"></div>
  <div class="relative z-10 max-w-screen-xl2 mx-auto px-6 lg:px-16 py-16 flex items-center min-h-[420px]" style="font-family: 'Tajawal', sans-serif;">
    <div class="max-w-lg">
      <span class="inline-block text-gold text-xs tracking-[0.35em] uppercase border border-gold/40 px-4 py-1.5 rounded mb-6" style="font-family: 'Cormorant Garamond', serif;">
        المنتج المميز
      </span>
      <h2 class="text-white font-black mb-3" style="font-size: clamp(1.8rem, 3.5vw, 3rem);">زيت عود ملكي فيتنامي</h2>
      <p class="text-gold/80 text-base italic mb-4" style="font-family: 'Cormorant Garamond', serif;">Vietnamese Royal Oud Oil</p>
      <p class="text-gray-400 text-sm leading-relaxed mb-8 max-w-sm">من أعمق غابات فيتنام — رائحة ملكية أصيلة تجمع بين العمق الخشبي والأناقة الشرقية.</p>
      <div class="flex items-center gap-4">
        <a href="{{ store.url }}/products" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-dark text-black font-bold px-8 py-4 rounded transition-all duration-300 shadow-gold">
          {{ trans('general.shop_now') }}
        </a>
        <a href="https://wa.me/{{ settings.whatsapp_number|default('966XXXXXXXXX') }}" target="_blank" rel="noopener" class="border border-white/30 hover:border-gold text-white hover:text-gold px-6 py-4 rounded transition-all duration-300 text-sm font-medium">
          {{ trans('general.whatsapp_order') }}
        </a>
      </div>
    </div>
  </div>
</section>

{# ── 6. Brand Story ── #}
<section class="py-14 lg:py-24 bg-white" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative order-2 lg:order-1">
        {% if settings.about_image %}
          <img src="{{ settings.about_image }}" alt="{{ trans('general.brand_story_title') }}" class="w-full rounded-2xl object-cover aspect-[4/5]" loading="lazy" />
        {% else %}
          <div class="w-full rounded-2xl bg-gradient-to-br from-dark-brown to-gray-900 aspect-[4/5] flex items-center justify-center">
            <p class="text-gold/40" style="font-family: 'Cormorant Garamond', serif; font-size: 1.5rem;">Brand Story Image</p>
          </div>
        {% endif %}
        <div class="absolute bottom-6 end-6 bg-white/95 backdrop-blur border border-gold/20 rounded-xl px-5 py-4 shadow-lg">
          <p class="text-gold font-black text-3xl">10+</p>
          <p class="text-gray-500 text-xs mt-0.5">سنوات من الخبرة</p>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <p class="text-gold text-sm tracking-[0.25em] uppercase mb-3" style="font-family: 'Cormorant Garamond', serif;">قصتنا</p>
        <h2 class="text-2xl lg:text-4xl font-black text-gray-900 mb-4">{{ trans('general.brand_story_title') }}</h2>
        <div class="w-10 h-0.5 bg-gold mb-6"></div>
        <p class="text-gray-600 leading-relaxed mb-5 text-sm lg:text-base">{{ trans('general.brand_story_text') }}</p>
        <p class="text-gray-600 leading-relaxed mb-8 text-sm lg:text-base">كل قطرة من زيوتنا وكل شريحة من عودنا تحكي قصة أرض غنية، وشغف لا ينتهي بتقديم الأفضل لكم.</p>
        <div class="grid grid-cols-3 gap-4 mb-8">
          {% for s in [{ n: '50+', l: 'منتج' }, { n: '10K+', l: 'عميل' }, { n: '100%', l: 'طبيعي' }] %}
            <div class="text-center py-4 border border-gray-100 rounded-xl">
              <p class="text-gold font-black text-2xl">{{ s.n }}</p>
              <p class="text-gray-400 text-xs mt-1">{{ s.l }}</p>
            </div>
          {% endfor %}
        </div>
        <a href="{{ store.url }}/pages/our-story" class="inline-flex items-center gap-2 border border-gold text-gold hover:bg-gold hover:text-black font-semibold px-7 py-3.5 rounded transition-all duration-300">
          {{ trans('general.learn_more') }}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

{# ── 7. Testimonials ── #}
<section class="py-14 lg:py-20 bg-gray-50" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6">
    <div class="text-center mb-10">
      <p class="text-gold text-sm tracking-[0.25em] uppercase mb-2" style="font-family: 'Cormorant Garamond', serif;">آراء عملائنا</p>
      <h2 class="text-2xl lg:text-3xl font-black text-gray-900">{{ trans('general.testimonials_title') }}</h2>
      <div class="w-10 h-0.5 bg-gold mx-auto mt-3"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {% for t in [
        { name: 'محمد العتيبي', city: 'الرياض', text: 'من أجود زيوت العود التي تذوقتها. الرائحة عميقة وأصيلة وتدوم طويلاً. سدوان تستحق كل التقدير.', stars: 5 },
        { name: 'فيصل الشمري', city: 'جدة',    text: 'شرائح العود الفيتنامي ممتازة جداً، الدخان كثيف والرائحة تملأ الغرفة. سأعيد الطلب حتماً.', stars: 5 },
        { name: 'عبدالله القحطاني', city: 'الدمام', text: 'التغليف فاخر جداً وجعل هديتي مميزة. خدمة العملاء سريعة الرد ومحترفة.', stars: 5 }
      ] %}
        <div class="bg-white border border-gray-100 hover:border-gold/30 rounded-2xl p-6 lg:p-8 transition-all duration-300 hover:shadow-card">
          <div class="flex gap-0.5 mb-4">
            {% for i in 1..t.stars %}<svg class="w-4 h-4 text-gold" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>{% endfor %}
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-6">"{{ t.text }}"</p>
          <div class="flex items-center gap-3 border-t border-gray-50 pt-4">
            <div class="w-9 h-9 rounded-full bg-gold/15 flex items-center justify-center text-gold font-bold text-sm">{{ t.name|slice(0,1) }}</div>
            <div>
              <p class="text-gray-900 font-semibold text-sm">{{ t.name }}</p>
              <p class="text-gray-400 text-xs">{{ t.city }}</p>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── 8. WhatsApp CTA ── #}
<section class="py-14 bg-dark-brown relative overflow-hidden" style="font-family: 'Tajawal', sans-serif;">
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 2px 2px, #C9A24A 1px, transparent 0); background-size: 22px 22px;"></div>
  <div class="relative z-10 max-w-screen-xl2 mx-auto px-4 text-center">
    <div class="w-14 h-14 rounded-full bg-green-500/20 border border-green-500/40 flex items-center justify-center mx-auto mb-5">
      <svg class="w-7 h-7 text-green-400" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a8.073 8.073 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479s1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.861 9.861 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </div>
    <h2 class="text-white font-black text-2xl lg:text-3xl mb-3">{{ trans('general.contact_expert') }}</h2>
    <p class="text-gray-300 text-sm max-w-md mx-auto mb-8">هل تبحث عن توصية شخصية؟ فريقنا من خبراء العود جاهز لمساعدتك في اختيار المنتج المثالي.</p>
    <a href="https://wa.me/{{ settings.whatsapp_number|default('966XXXXXXXXX') }}"
       target="_blank" rel="noopener"
       class="inline-flex items-center gap-3 bg-green-500 hover:bg-green-400 text-white font-bold px-8 py-4 rounded-xl transition-all duration-300 shadow-lg">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a8.073 8.073 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479s1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.861 9.861 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      {{ trans('general.chat_now') }}
    </a>
  </div>
</section>

{# ── 9. Newsletter ── #}
<section class="py-14 bg-white border-t border-gray-100" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-2xl mx-auto px-4 text-center">
    <p class="text-gold text-sm tracking-[0.25em] uppercase mb-3" style="font-family: 'Cormorant Garamond', serif;">Newsletter</p>
    <h2 class="text-2xl lg:text-3xl font-black text-gray-900 mb-2">{{ trans('general.newsletter_title') }}</h2>
    <p class="text-gray-500 text-sm mb-7">{{ trans('general.newsletter_subtitle') }}</p>
    <salla-newsletter class="w-full max-w-md mx-auto"></salla-newsletter>
  </div>
</section>

{% endblock %}
