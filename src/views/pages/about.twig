{% extends 'layouts/master.twig' %}
{% block title %}{{ trans('general.about') }} | {{ store.name }}{% endblock %}

{% block content %}
<section class="py-20 bg-gray-900 text-center relative overflow-hidden" style="font-family: 'Tajawal', sans-serif;">
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 2px 2px, #C9A24A 1px, transparent 0); background-size: 28px 28px;"></div>
  <div class="relative z-10 max-w-2xl mx-auto px-4">
    <p class="text-gold text-sm tracking-[0.35em] uppercase mb-4" style="font-family: 'Cormorant Garamond', serif;">Our Story</p>
    <h1 class="text-white font-black mb-4" style="font-size: clamp(2rem, 4vw, 3.5rem);">{{ trans('general.about') }}</h1>
    <div class="w-14 h-0.5 bg-gold mx-auto mb-5"></div>
    <p class="text-gray-400 italic" style="font-family: 'Cormorant Garamond', serif; font-size: 1.15rem;">"Luxury Vietnamese oud — crafted for those who appreciate true elegance."</p>
  </div>
</section>

<section class="py-14 lg:py-24 bg-white" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
      <div class="relative">
        {% if theme.settings.get('about_image', '') %}
          <img src="{{ theme.settings.get('about_image', '') }}" alt="{{ store.name }}" class="w-full rounded-2xl object-cover aspect-[4/5]" loading="lazy" />
        {% else %}
          <div class="w-full rounded-2xl bg-gradient-to-br from-dark-brown to-gray-900 aspect-[4/5] flex items-center justify-center">
            <p class="text-gold/40 text-xl" style="font-family: 'Cormorant Garamond', serif;">Brand Story Image</p>
          </div>
        {% endif %}
        <div class="absolute bottom-6 end-6 bg-white border border-gold/20 rounded-xl px-5 py-4 shadow-card">
          <p class="text-gold font-black text-3xl">10+</p>
          <p class="text-gray-500 text-xs mt-0.5">سنوات من الخبرة</p>
        </div>
      </div>
      <div>
        <p class="text-gold text-sm tracking-[0.25em] uppercase mb-3" style="font-family: 'Cormorant Garamond', serif;">البداية</p>
        <h2 class="text-2xl lg:text-4xl font-black text-gray-900 mb-4">{{ trans('general.brand_story_title') }}</h2>
        <div class="w-10 h-0.5 bg-gold mb-6"></div>
        <div class="space-y-4 text-gray-600 text-sm lg:text-base leading-relaxed">
          <p>{{ trans('general.brand_story_text') }}</p>
          <p>كل قطرة من زيوتنا وكل شريحة من عودنا تحكي قصة أرض غنية، وحرفيين ماهرين، وشغف لا ينتهي بتقديم الأفضل لكم.</p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      {% for v in [
        { title: 'الجودة أولاً', desc: 'نختار كل منتج بعناية شديدة لضمان أعلى مستويات الجودة والأصالة.' },
        { title: 'الشغف الحقيقي', desc: 'شغفنا بالعود هو ما يدفعنا لتقديم الأفضل دائماً.' },
        { title: 'خدمة شخصية', desc: 'فريقنا من الخبراء جاهز لمساعدتك في اختيار العطر المثالي.' }
      ] %}
        <div class="bg-gray-50 border border-gray-100 rounded-2xl p-7 text-center">
          <h3 class="font-black text-gray-900 text-lg mb-3">{{ v.title }}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{{ v.desc }}</p>
        </div>
      {% endfor %}
    </div>

    <div class="bg-dark-brown rounded-2xl p-10 text-center">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {% for s in [{ n: '10+', l: 'سنوات' }, { n: '50+', l: 'منتج فاخر' }, { n: '10K+', l: 'عميل سعيد' }, { n: '100%', l: 'طبيعي' }] %}
          <div>
            <p class="text-gold font-black text-3xl lg:text-4xl mb-1">{{ s.n }}</p>
            <p class="text-gray-400 text-sm">{{ s.l }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section class="py-14 bg-gray-50 text-center" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-xl mx-auto px-4">
    <h2 class="text-2xl font-black text-gray-900 mb-4">ابدأ رحلتك مع العود الأصيل</h2>
    <p class="text-gray-500 text-sm mb-7">اكتشف مجموعتنا أو تواصل مع خبرائنا للحصول على توصية شخصية.</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="{{ store.url }}/categories" class="bg-gold hover:bg-gold-dark text-black font-bold px-7 py-3.5 rounded-xl transition-all duration-300">{{ trans('general.shop_now') }}</a>
      <a href="https://wa.me/{{ theme.settings.get('whatsapp_number', '966XXXXXXXXX')|default('966XXXXXXXXX') }}" target="_blank" rel="noopener" class="border border-gold text-gold hover:bg-gold hover:text-black px-7 py-3.5 rounded-xl transition-all duration-300 font-medium">{{ trans('general.contact_expert') }}</a>
    </div>
  </div>
</section>
{% endblock %}
