{% extends 'layouts/master.twig' %}

{% block title %}{{ product.name }} | {{ store.name }}{% endblock %}
{% block description %}{{ product.description|striptags|slice(0, 155) }}{% endblock %}
{% block og_image %}{{ product.image.url|default(product.image) }}{% endblock %}

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.name|escape('js') }}",
  "image": "{{ product.image.url|default(product.image)|escape('js') }}",
  "description": "{{ product.description|striptags|escape('js') }}",
  "sku": "{{ product.sku|escape('js') }}",
  "offers": {
    "@type": "Offer",
    "price": "{{ product.price.current }}",
    "priceCurrency": "SAR",
    "availability": "https://schema.org/{{ product.availability == 'in_stock' ? 'InStock' : 'OutOfStock' }}"
  }
}
</script>
{% endblock %}

{% block content %}

{# Breadcrumb #}
<nav class="bg-brand-gray border-b border-gold/10 py-3">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-8">
    <ol class="flex items-center gap-2 text-xs text-ivory/50 list-none m-0 p-0 flex-wrap">
      <li><a href="{{ store.url }}" class="hover:text-gold transition-colors">{{ 'الرئيسية' | trans }}</a></li>
      <li class="text-gold/30">›</li>
      {% if product.category %}
        <li><a href="{{ product.category.url }}" class="hover:text-gold transition-colors">{{ product.category.name }}</a></li>
        <li class="text-gold/30">›</li>
      {% endif %}
      <li class="text-gold line-clamp-1">{{ product.name }}</li>
    </ol>
  </div>
</nav>

{# Product main section #}
<section class="py-10 lg:py-16 bg-black">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">

      {# ── Images ── #}
      <div class="space-y-4">
        {# Main image #}
        <div class="relative overflow-hidden rounded-xl bg-brand-gray aspect-square group cursor-zoom-in" id="main-image-wrap">
          <img id="main-product-image"
               src="{{ product.image.url|default(product.image) }}"
               alt="{{ product.name }}"
               class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
          {% if product.discount_percent %}
            <div class="absolute top-4 start-4 bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-full">
              -{{ product.discount_percent }}%
            </div>
          {% endif %}
          {% if product.is_new %}
            <div class="absolute top-4 end-4 bg-gold text-black text-xs font-bold px-3 py-1 rounded-full">
              {{ 'جديد' | trans }}
            </div>
          {% endif %}
        </div>

        {# Thumbnails #}
        {% if product.images is defined and product.images|length > 1 %}
          <div class="flex gap-3 overflow-x-auto pb-1">
            {% for img in product.images %}
              <button class="thumb-btn shrink-0 w-16 h-16 rounded-lg overflow-hidden border-2 transition-all duration-200 {{ loop.first ? 'border-gold' : 'border-white/10 hover:border-gold/50' }}"
                      data-src="{{ img.url|default(img) }}"
                      onclick="setMainImage(this)">
                <img src="{{ img.url|default(img) }}" alt="{{ product.name }}" class="w-full h-full object-cover" />
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {# ── Product Info ── #}
      <div class="flex flex-col">

        {# Name + rating #}
        <div class="mb-4">
          <h1 class="font-tajawal font-black text-white mb-1" style="font-size: clamp(1.6rem, 3vw, 2.5rem); line-height: 1.2;">
            {{ product.name }}
          </h1>
          {% if product.subtitle is defined %}
            <p class="font-cormorant text-gold italic text-lg mb-2">{{ product.subtitle }}</p>
          {% endif %}
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-1">
              {% for i in 1..5 %}
                <svg class="w-4 h-4 {{ i <= product.rating|default(5) ? 'text-gold' : 'text-white/20' }}" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              {% endfor %}
            </div>
            {% if product.rating_count is defined %}
              <span class="text-ivory/40 text-sm">({{ product.rating_count }} {{ 'تقييم' | trans }})</span>
            {% endif %}
          </div>
        </div>

        {# Price #}
        <div class="flex items-baseline gap-3 mb-6 pb-6 border-b border-white/8">
          <span class="font-tajawal font-black text-gold text-3xl">{{ product.price.current }}</span>
          <span class="text-ivory/60 text-base">{{ store.currency|default('ر.س') }}</span>
          {% if product.price.old %}
            <span class="text-ivory/40 text-lg line-through">{{ product.price.old }} {{ store.currency|default('ر.س') }}</span>
          {% endif %}
        </div>

        {# Short description #}
        {% if product.short_description %}
          <p class="text-ivory/70 text-sm leading-relaxed mb-6">{{ product.short_description }}</p>
        {% endif %}

        {# Scent notes pyramid #}
        <div class="mb-6 bg-brand-gray/50 border border-gold/15 rounded-xl p-5">
          <h3 class="font-tajawal font-semibold text-gold text-sm mb-4 uppercase tracking-widest">{{ 'هرم العطر' | trans }}</h3>
          <div class="space-y-3">
            {% for note in [
              { level: 'القمة', level_en: 'Top Notes', notes: product.scent_top|default('الحمضيات، التوابل'), color: 'border-gold/60' },
              { level: 'القلب', level_en: 'Heart Notes', notes: product.scent_heart|default('العود، الورد'), color: 'border-gold/40' },
              { level: 'القاعدة', level_en: 'Base Notes', notes: product.scent_base|default('المسك، الأمبر'), color: 'border-gold/25' }
            ] %}
              <div class="flex items-center gap-4">
                <div class="shrink-0 text-end" style="width: 70px;">
                  <p class="text-ivory text-xs font-medium">{{ note.level }}</p>
                  <p class="text-ivory/40 text-xs font-cormorant italic">{{ note.level_en }}</p>
                </div>
                <div class="flex-1 h-px bg-gold/20"></div>
                <p class="text-ivory/70 text-xs">{{ note.notes }}</p>
              </div>
            {% endfor %}
          </div>
        </div>

        {# Options / variants #}
        {% if product.options is defined and product.options|length > 0 %}
          <div class="mb-6 space-y-4">
            {% for option in product.options %}
              <div>
                <label class="block text-ivory/80 text-sm font-medium mb-2">
                  {{ option.name }}
                  <span class="text-gold ms-1" id="selected-{{ option.id }}"></span>
                </label>
                {% if option.type == 'color' %}
                  <div class="flex flex-wrap gap-2">
                    {% for value in option.values %}
                      <button class="option-swatch w-8 h-8 rounded-full border-2 border-transparent hover:border-gold transition-all duration-200 relative"
                              style="background: {{ value.color }};"
                              data-value="{{ value.name }}"
                              data-option="{{ option.id }}"
                              title="{{ value.name }}">
                      </button>
                    {% endfor %}
                  </div>
                {% else %}
                  <div class="flex flex-wrap gap-2">
                    {% for value in option.values %}
                      <button class="option-btn px-4 py-2 border border-white/15 hover:border-gold text-ivory/70 hover:text-gold text-sm rounded transition-all duration-200"
                              data-value="{{ value.name }}"
                              data-option="{{ option.id }}">
                        {{ value.name }}
                      </button>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {# Quantity + Add to cart #}
        <div class="flex items-stretch gap-3 mb-4">
          <div class="flex items-center border border-white/15 rounded overflow-hidden">
            <button class="qty-btn w-10 h-12 flex items-center justify-center text-ivory/70 hover:text-gold hover:bg-white/5 transition-colors text-lg"
                    onclick="changeQty(-1)">−</button>
            <input type="number" id="qty" value="1" min="1"
                   class="w-12 h-12 bg-transparent text-center text-ivory text-base focus:outline-none" />
            <button class="qty-btn w-10 h-12 flex items-center justify-center text-ivory/70 hover:text-gold hover:bg-white/5 transition-colors text-lg"
                    onclick="changeQty(1)">+</button>
          </div>
          <salla-add-product-button product-id="{{ product.id }}"
            class="flex-1 inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-light text-black font-tajawal font-bold text-base h-12 rounded transition-all duration-300 shadow-gold hover:shadow-gold-lg cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            {{ 'أضف للسلة' | trans }}
          </salla-add-product-button>
        </div>

        {# WhatsApp order button #}
        <a href="https://wa.me/{{ settings.whatsapp_number|default('966XXXXXXXXX') }}?text={{ ('أريد الطلب: ' ~ product.name ~ ' - ' ~ store.url ~ product.url) | url_encode }}"
           target="_blank" rel="noopener noreferrer"
           class="flex items-center justify-center gap-2 border border-green-500/50 text-green-400 hover:bg-green-500/10 font-tajawal font-semibold text-sm h-12 rounded transition-all duration-300 mb-6">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {{ 'اطلب عبر واتساب' | trans }}
        </a>

        {# Meta info (SKU, availability) #}
        <div class="flex flex-wrap gap-4 text-xs text-ivory/40 mb-4">
          {% if product.sku %}<span>{{ 'SKU:' }} {{ product.sku }}</span>{% endif %}
          <span class="{{ product.availability == 'in_stock' ? 'text-green-400' : 'text-red-400' }}">
            ● {{ product.availability == 'in_stock' ? ('متوفر' | trans) : ('غير متوفر' | trans) }}
          </span>
        </div>

        {# Wishlist + Share #}
        <div class="flex items-center gap-4 pt-4 border-t border-white/8">
          <button onclick="salla.wishlist.toggle(event, {{ product.id }})"
            class="flex items-center gap-2 text-ivory/50 hover:text-red-400 text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
            {{ 'أضف للمفضلة' | trans }}
          </button>
          <button onclick="navigator.share ? navigator.share({ title: document.title, url: location.href }) : null"
            class="flex items-center gap-2 text-ivory/50 hover:text-gold text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
            </svg>
            {{ 'مشاركة' | trans }}
          </button>
        </div>
      </div>
    </div>

    {# ── Product Tabs ── #}
    <div class="mt-16">
      {# Tab navigation #}
      <div class="flex border-b border-white/10 gap-0 overflow-x-auto">
        {% for tab in [
          { id: 'description', label: 'الوصف' },
          { id: 'details',     label: 'التفاصيل' },
          { id: 'shipping',    label: 'الشحن والإرجاع' }
        ] %}
          <button class="tab-btn shrink-0 px-6 py-4 text-sm font-medium border-b-2 transition-all duration-200
                         {{ loop.first ? 'border-gold text-gold' : 'border-transparent text-ivory/50 hover:text-ivory' }}"
                  data-tab="{{ tab.id }}">
            {{ tab.label | trans }}
          </button>
        {% endfor %}
      </div>

      {# Tab panels #}
      <div id="tab-description" class="tab-panel pt-8 max-w-3xl">
        <div class="prose prose-invert prose-sm text-ivory/70 leading-relaxed">
          {{ product.description|raw }}
        </div>
      </div>

      <div id="tab-details" class="tab-panel pt-8 hidden">
        <table class="w-full max-w-lg text-sm">
          {% for row in [
            { key: 'الوزن', val: product.weight ~ ' جم' },
            { key: 'المنشأ', val: 'فيتنام' },
            { key: 'نوع العطر', val: 'عود طبيعي' },
            { key: 'مدة الثبات', val: '12-24 ساعة' }
          ] %}
            <tr class="border-b border-white/8">
              <td class="py-3 pe-8 text-ivory/50 font-medium">{{ row.key | trans }}</td>
              <td class="py-3 text-ivory/80">{{ row.val }}</td>
            </tr>
          {% endfor %}
        </table>
      </div>

      <div id="tab-shipping" class="tab-panel pt-8 hidden max-w-2xl">
        <div class="space-y-4 text-sm text-ivory/70">
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
            </svg>
            <p>{{ 'شحن مجاني للطلبات فوق 300 ريال داخل المملكة العربية السعودية.' | trans }}</p>
          </div>
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
            </svg>
            <p>{{ 'التوصيل خلال 2-5 أيام عمل.' | trans }}</p>
          </div>
          <div class="flex gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
            </svg>
            <p>{{ 'إمكانية الإرجاع خلال 7 أيام من تاريخ الاستلام (المنتج بحالته الأصلية).' | trans }}</p>
          </div>
        </div>
      </div>
    </div>

    {# ── Related Products ── #}
    {% if related_products is defined and related_products|length > 0 %}
      <section class="mt-20 pt-10 border-t border-white/8">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="font-cormorant text-gold/70 text-sm tracking-[0.3em] uppercase mb-2">{{ 'قد يعجبك أيضاً' | trans }}</p>
            <h2 class="font-tajawal font-black text-white text-2xl lg:text-3xl">{{ 'منتجات ذات صلة' | trans }}</h2>
          </div>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
          {% for related in related_products|slice(0, 4) %}
            {% include 'components/product-card.twig' with { product: related } %}
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>
</section>

{% endblock %}

{% block scripts %}
<script>
// Thumbnail switcher
function setMainImage(btn) {
  document.getElementById('main-product-image').src = btn.dataset.src;
  document.querySelectorAll('.thumb-btn').forEach(b => {
    b.classList.toggle('border-gold', b === btn);
    b.classList.toggle('border-white/10', b !== btn);
  });
}

// Quantity control
function changeQty(delta) {
  const inp = document.getElementById('qty');
  inp.value = Math.max(1, parseInt(inp.value) + delta);
}

// Tabs
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => {
      b.classList.toggle('border-gold', b === btn);
      b.classList.toggle('text-gold', b === btn);
      b.classList.toggle('border-transparent', b !== btn);
      b.classList.toggle('text-ivory/50', b !== btn);
    });
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
    document.getElementById('tab-' + btn.dataset.tab).classList.remove('hidden');
  });
});

// Option buttons
document.querySelectorAll('.option-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const group = btn.dataset.option;
    document.querySelectorAll(`.option-btn[data-option="${group}"]`).forEach(b => {
      b.classList.toggle('border-gold', b === btn);
      b.classList.toggle('text-gold', b === btn);
      b.classList.toggle('border-white/15', b !== btn);
      b.classList.toggle('text-ivory/70', b !== btn);
    });
    const label = document.getElementById('selected-' + group);
    if (label) label.textContent = '— ' + btn.dataset.value;
  });
});
</script>
{% endblock %}
