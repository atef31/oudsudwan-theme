{% extends 'layouts/master.twig' %}
{% block title %}{{ product.name }} | {{ store.name }}{% endblock %}
{% block og_image %}{{ product.image.url }}{% endblock %}

{% block content %}
<div class="max-w-screen-xl2 mx-auto px-4 lg:px-6 py-4" style="font-family: 'Tajawal', sans-serif;">
  <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
    <a href="{{ store.url }}" class="hover:text-gold transition-colors">{{ trans('general.home') }}</a>
    <span>›</span>
    {% if product.category %}<a href="{{ product.category.url }}" class="hover:text-gold transition-colors">{{ product.category.name }}</a><span>›</span>{% endif %}
    <span class="text-gray-900 line-clamp-1">{{ product.name }}</span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 mb-16">

    {# Images #}
    <div class="space-y-4">
      <div class="relative overflow-hidden rounded-2xl bg-gray-50 aspect-square">
        <img id="main-img" src="{{ product.image.url|default(product.image) }}" alt="{{ product.name }}" class="w-full h-full object-cover" />
        {% if product.discount_percent %}<div class="absolute top-4 start-4 bg-red-500 text-white text-sm font-bold px-3 py-1 rounded-full">-{{ product.discount_percent }}%</div>{% endif %}
      </div>
      {% if product.images is defined and product.images|length > 1 %}
        <div class="flex gap-3 overflow-x-auto pb-1">
          {% for img in product.images %}
            <button onclick="document.getElementById('main-img').src='{{ img.url|default(img) }}'"
              class="shrink-0 w-16 h-16 rounded-xl overflow-hidden border-2 border-transparent hover:border-gold transition-colors">
              <img src="{{ img.url|default(img) }}" alt="{{ product.name }}" loading="lazy" class="w-full h-full object-cover" />
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {# Info #}
    <div style="font-family: 'Tajawal', sans-serif;">
      <h1 class="text-2xl lg:text-3xl font-black text-gray-900 mb-2">{{ product.name }}</h1>
      {% if product.subtitle %}<p class="text-gold italic mb-3" style="font-family: 'Cormorant Garamond', serif;">{{ product.subtitle }}</p>{% endif %}
      <salla-rating-stars product-id="{{ product.id }}" class="mb-4 text-gold"></salla-rating-stars>

      <div class="flex items-baseline gap-3 mb-6 pb-6 border-b border-gray-100">
        <span class="text-gold font-black text-3xl">{{ product.price.current }}</span>
        <span class="text-gray-400 text-sm">{{ trans('general.sar') }}</span>
        {% if product.price.old %}<span class="text-gray-400 text-base line-through">{{ product.price.old }} {{ trans('general.sar') }}</span>{% endif %}
      </div>

      {% if product.short_description %}<p class="text-gray-600 text-sm leading-relaxed mb-6">{{ product.short_description }}</p>{% endif %}

      {% if product.options is defined and product.options|length %}
        <div class="space-y-4 mb-6">
          {% for opt in product.options %}
            <div>
              <label class="block text-gray-700 text-sm font-medium mb-2">{{ opt.name }}</label>
              <div class="flex flex-wrap gap-2">
                {% for v in opt.values %}
                  <button class="px-4 py-2 border border-gray-200 hover:border-gold text-sm rounded-lg transition-colors">{{ v.name }}</button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      <div class="flex gap-3 mb-4">
        <salla-add-product-button product-id="{{ product.id }}"
          class="flex-1 flex items-center justify-center gap-2 bg-gold hover:bg-gold-dark text-black font-bold py-4 rounded-xl transition-all cursor-pointer shadow-gold text-base">
          {{ trans('general.add_to_cart') }}
        </salla-add-product-button>
      </div>

      <a href="https://wa.me/{{ theme.settings.get('whatsapp_number', '966XXXXXXXXX')|default('966XXXXXXXXX') }}?text={{ (trans('general.whatsapp_order') ~ ': ' ~ product.name) | url_encode }}"
         target="_blank" rel="noopener"
         class="flex items-center justify-center gap-2 border border-green-500/50 text-green-600 hover:bg-green-50 font-medium py-3.5 rounded-xl transition-all text-sm mb-6">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a8.073 8.073 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479s1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.861 9.861 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        {{ trans('general.whatsapp_order') }}
      </a>

      <div class="flex items-center gap-4 text-xs text-gray-400">
        {% if product.sku %}<span>SKU: {{ product.sku }}</span><span>|</span>{% endif %}
        <span class="{{ product.availability == 'in_stock' ? 'text-green-500' : 'text-red-400' }}">
          ● {{ product.availability == 'in_stock' ? trans('general.in_stock') : trans('general.out_of_stock') }}
        </span>
      </div>
    </div>
  </div>

  {# Description tabs #}
  {% if product.description %}
    <div class="mb-16">
      <div class="border-b border-gray-100 mb-6">
        <button class="px-6 py-3 text-sm font-medium text-gold border-b-2 border-gold -mb-px">الوصف</button>
      </div>
      <div class="prose prose-sm max-w-none text-gray-600">{{ product.description|raw }}</div>
    </div>
  {% endif %}

  {# Related products #}
  {% if related_products is defined and related_products|length %}
    <div>
      <h2 class="text-xl font-black text-gray-900 mb-6">منتجات ذات صلة</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        {% for product in related_products|slice(0,4) %}{% include 'components/product-card.twig' %}{% endfor %}
      </div>
    </div>
  {% endif %}
</div>
{% endblock %}
