<article class="group relative bg-white rounded-xl overflow-hidden border border-gray-100 hover:border-gold/40 transition-all duration-300 hover:shadow-card flex flex-col" style="font-family: 'Tajawal', sans-serif;">

  {# Image #}
  <a href="{{ product.url }}" class="block relative overflow-hidden aspect-square bg-gray-50">
    <img src="{{ product.image.url|default(product.image) }}"
         alt="{{ product.name }}"
         loading="lazy"
         class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />

    {# Badges #}
    <div class="absolute top-3 start-3 flex flex-col gap-1.5">
      {% if product.is_new %}<span class="bg-gold text-black text-xs font-bold px-2.5 py-1 rounded">{{ trans('general.new') }}</span>{% endif %}
      {% if product.discount_percent %}<span class="bg-red-500 text-white text-xs font-bold px-2.5 py-1 rounded">-{{ product.discount_percent }}%</span>{% endif %}
    </div>

    {# Wishlist #}
    <salla-wishlist-button product-id="{{ product.id }}"
      class="absolute top-3 end-3 w-8 h-8 rounded-full bg-white/80 backdrop-blur-sm flex items-center justify-center text-gray-500 hover:text-red-400 transition-all opacity-0 group-hover:opacity-100"></salla-wishlist-button>

    {# Quick shop overlay #}
    <div class="absolute bottom-0 inset-x-0 p-3 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
      <salla-add-product-button product-id="{{ product.id }}"
        class="w-full flex items-center justify-center gap-2 bg-gold hover:bg-gold-dark text-black text-sm font-bold py-2.5 rounded-lg transition-colors cursor-pointer">
        {{ trans('general.add_to_cart') }}
      </salla-add-product-button>
    </div>
  </a>

  {# Info #}
  <div class="flex flex-col flex-1 p-4">
    {# Stars #}
    <salla-rating-stars product-id="{{ product.id }}" class="mb-2 text-gold"></salla-rating-stars>

    {# Name #}
    <a href="{{ product.url }}" class="block flex-1">
      <h3 class="font-semibold text-gray-900 text-base leading-snug mb-1 line-clamp-2 group-hover:text-gold transition-colors">{{ product.name }}</h3>
      {% if product.subtitle %}<p class="text-gold text-xs italic mb-2" style="font-family: 'Cormorant Garamond', serif;">{{ product.subtitle }}</p>{% endif %}
    </a>

    {# Price + CTA #}
    <div class="flex items-center justify-between mt-3">
      <div>
        <span class="text-gold font-bold text-lg">{{ product.price.current }}</span>
        <span class="text-gray-400 text-xs ms-1">{{ trans('general.sar') }}</span>
        {% if product.price.old %}<span class="text-gray-400 text-xs line-through ms-2">{{ product.price.old }}</span>{% endif %}
      </div>
      <salla-add-product-button product-id="{{ product.id }}"
        class="flex items-center justify-center w-9 h-9 rounded-full bg-gold/10 hover:bg-gold text-gold hover:text-black transition-all duration-200 cursor-pointer">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      </salla-add-product-button>
    </div>
  </div>
</article>
