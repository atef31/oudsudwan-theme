{#
  Reusable product card component.
  Usage: {% include 'components/product-card.twig' with { product: product } %}
#}
<article class="product-card group relative bg-brand-gray rounded-lg overflow-hidden border border-white/5 hover:border-gold/30 transition-all duration-400 shadow-card hover:shadow-card-hover flex flex-col">

  {# Image wrapper #}
  <a href="{{ product.url }}" class="block relative overflow-hidden aspect-square bg-black shrink-0">
    <img src="{{ product.image.url|default(product.image) }}"
         alt="{{ product.name }}"
         loading="lazy"
         class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />

    {# Overlay on hover #}
    <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

    {# Badges #}
    <div class="absolute top-3 start-3 flex flex-col gap-1.5">
      {% if product.is_new %}
        <span class="badge bg-gold text-black text-xs font-bold px-2.5 py-1 rounded">{{ 'جديد' | trans }}</span>
      {% endif %}
      {% if product.is_bestseller %}
        <span class="badge bg-brand-gray text-gold border border-gold/50 text-xs font-bold px-2.5 py-1 rounded">{{ 'الأكثر مبيعاً' | trans }}</span>
      {% endif %}
      {% if product.discount_percent %}
        <span class="badge bg-red-600 text-white text-xs font-bold px-2.5 py-1 rounded">-{{ product.discount_percent }}%</span>
      {% endif %}
    </div>

    {# Wishlist #}
    <button class="absolute top-3 end-3 w-8 h-8 rounded-full bg-black/50 backdrop-blur-sm flex items-center justify-center text-ivory/70 hover:text-red-400 transition-colors duration-200 opacity-0 group-hover:opacity-100"
            onclick="salla.wishlist.toggle(event, {{ product.id }})"
            aria-label="{{ 'إضافة للمفضلة' | trans }}">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
      </svg>
    </button>

    {# Quick view on hover #}
    <div class="absolute bottom-3 inset-x-3 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
      <a href="{{ product.url }}"
        class="block w-full text-center bg-black/80 backdrop-blur-sm text-ivory text-xs py-2 rounded border border-gold/30 hover:bg-gold hover:text-black transition-colors duration-200">
        {{ 'عرض سريع' | trans }}
      </a>
    </div>
  </a>

  {# Card body #}
  <div class="flex flex-col flex-1 p-4">

    {# Star rating #}
    <div class="flex items-center gap-1 mb-2">
      {% set rating = product.rating|default(5) %}
      {% for i in 1..5 %}
        <svg class="w-3.5 h-3.5 {{ i <= rating ? 'text-gold' : 'text-white/20' }}" viewBox="0 0 20 20" fill="currentColor">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      {% endfor %}
      {% if product.rating_count is defined %}
        <span class="text-ivory/40 text-xs ms-1">({{ product.rating_count }})</span>
      {% endif %}
    </div>

    {# Product name #}
    <a href="{{ product.url }}" class="block flex-1">
      <h3 class="font-tajawal font-semibold text-ivory text-base leading-snug mb-1 line-clamp-2 group-hover:text-gold transition-colors duration-200">
        {{ product.name }}
      </h3>
      {% if product.subtitle is defined %}
        <p class="font-cormorant text-gold/70 text-sm italic mb-2">{{ product.subtitle }}</p>
      {% endif %}
      {% if product.description is defined %}
        <p class="text-ivory/50 text-xs leading-relaxed line-clamp-2 mb-3">{{ product.description }}</p>
      {% endif %}
    </a>

    {# Price + CTA #}
    <div class="flex items-center justify-between mt-3 gap-2">
      <div class="flex flex-col">
        <span class="text-gold font-tajawal font-bold text-lg leading-none">
          {{ product.price.current }} {{ store.currency|default('ر.س') }}
        </span>
        {% if product.price.old %}
          <span class="text-ivory/40 text-xs line-through mt-0.5">
            {{ product.price.old }} {{ store.currency|default('ر.س') }}
          </span>
        {% endif %}
      </div>

      <salla-add-product-button product-id="{{ product.id }}"
        class="shrink-0 inline-flex items-center gap-1.5 bg-gold hover:bg-gold-dark text-black text-xs font-bold px-4 py-2.5 rounded transition-colors duration-200 cursor-pointer">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        {{ 'أضف للسلة' | trans }}
      </salla-add-product-button>
    </div>
  </div>
</article>
