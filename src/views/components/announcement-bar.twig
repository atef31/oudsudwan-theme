<div id="announcement-bar" class="bg-gold text-black text-center text-sm font-medium py-2.5 px-4 relative" style="font-family: 'Tajawal', sans-serif;">
  <span class="tracking-wide">
    {{ settings.announcement_text|default(trans('general.announcement')) }}
  </span>
  <button onclick="document.getElementById('announcement-bar').remove(); sessionStorage.setItem('ann_closed','1')"
          class="absolute top-1/2 -translate-y-1/2 end-4 text-black/60 hover:text-black transition-colors"
          aria-label="{{ trans('general.close') }}">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
</div>
<script>if(sessionStorage.getItem('ann_closed')){var b=document.getElementById('announcement-bar');if(b)b.remove();}</script>
