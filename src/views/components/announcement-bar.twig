<div id="announcement-bar" class="bg-gold text-black text-center text-sm font-tajawal font-medium py-2 px-4 relative">
  <span class="tracking-wide">
    {% if store.direction == 'rtl' %}
      {{ settings.announcement_text_ar|default('شحن مجاني للطلبات فوق 300 ريال | Free shipping over 300 SAR') }}
    {% else %}
      {{ settings.announcement_text_en|default('Free shipping on orders over 300 SAR | شحن مجاني للطلبات فوق 300 ريال') }}
    {% endif %}
  </span>
  <button onclick="document.getElementById('announcement-bar').remove()"
          aria-label="إغلاق"
          class="absolute top-1/2 -translate-y-1/2 end-3 text-black/70 hover:text-black transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
</div>
