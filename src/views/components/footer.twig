<footer class="bg-gray-900 text-gray-300 pt-14 pb-8" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6">

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      {# Col 1 — Brand #}
      <div>
        <a href="{{ store.url }}" class="inline-block mb-5">
          {% if store.logo %}
            <img src="{{ store.logo }}" alt="{{ store.name }}" class="h-10 w-auto brightness-0 invert" />
          {% else %}
            <span class="text-white font-bold text-xl tracking-widest" style="font-family: 'Cormorant Garamond', serif;">OUDSUDWAN</span>
          {% endif %}
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mb-5">{{ store.description|default('زيوت العود الفيتنامي الفاخرة — شرائح عود، بخور، ومنتجات عود أصيلة.') }}</p>
        <div class="flex gap-3">
          {% if store.socials is defined %}
            {% for social in store.socials %}
              <a href="{{ social.url }}" target="_blank" rel="noopener" aria-label="{{ social.name }}"
                class="w-9 h-9 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 hover:text-gold hover:border-gold transition-colors">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="{{ social.icon }}"/></svg>
              </a>
            {% endfor %}
          {% else %}
            {% for s in [
              { label: 'Instagram', path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z', href: '#' },
              { label: 'Twitter/X', path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.776-8.906L1.645 2.25h6.921l4.26 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z', href: '#' }
            ] %}
              <a href="{{ s.href }}" aria-label="{{ s.label }}" class="w-9 h-9 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 hover:text-gold hover:border-gold transition-colors">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="{{ s.path }}"/></svg>
              </a>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      {# Col 2 — Collection #}
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-5">{{ trans('general.collection') }}</h3>
        <ul class="space-y-2.5 list-none m-0 p-0">
          {% for item in [
            { l: trans('general.oud_oil'),   h: '/categories/oud-oil' },
            { l: trans('general.oud_chips'), h: '/categories/oud-chips' },
            { l: trans('general.incense'),   h: '/categories/incense' },
            { l: trans('general.gift_sets'), h: '/categories/gift-sets' },
            { l: trans('general.best_sellers'), h: '/categories/best-sellers' }
          ] %}
            <li><a href="{{ store.url }}{{ item.h }}" class="text-gray-400 hover:text-gold text-sm transition-colors flex items-center gap-2 group">
              <span class="w-0 group-hover:w-3 h-px bg-gold transition-all duration-200"></span>{{ item.l }}
            </a></li>
          {% endfor %}
        </ul>
      </div>

      {# Col 3 — Support #}
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-5">{{ trans('general.contact') }}</h3>
        <ul class="space-y-2.5 list-none m-0 p-0">
          {% for item in [
            { l: 'سياسة الاسترجاع',  h: '/pages/return-policy' },
            { l: 'الشحن والتوصيل',    h: '/pages/shipping' },
            { l: 'الأسئلة الشائعة',   h: '/pages/faq' },
            { l: 'تتبع طلبك',          h: '/orders/tracking' },
            { l: trans('general.contact'), h: '/pages/contact' }
          ] %}
            <li><a href="{{ store.url }}{{ item.h }}" class="text-gray-400 hover:text-gold text-sm transition-colors flex items-center gap-2 group">
              <span class="w-0 group-hover:w-3 h-px bg-gold transition-all duration-200"></span>{{ item.l }}
            </a></li>
          {% endfor %}
        </ul>
      </div>

      {# Col 4 — Contact #}
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-5">تواصل معنا</h3>
        <div class="space-y-3">
          <a href="https://wa.me/{{ settings.whatsapp_number|default('966XXXXXXXXX') }}" class="flex items-center gap-3 text-gray-400 hover:text-gold transition-colors text-sm">
            <svg class="w-4 h-4 text-green-400 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a8.073 8.073 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479s1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.861 9.861 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            +{{ settings.whatsapp_number|default('966XXXXXXXXX') }}
          </a>
          <a href="mailto:{{ store.email|default('info@oudsudwan.com') }}" class="flex items-center gap-3 text-gray-400 hover:text-gold transition-colors text-sm">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {{ store.email|default('info@oudsudwan.com') }}
          </a>
          <p class="flex items-center gap-3 text-gray-400 text-sm">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            المملكة العربية السعودية
          </p>
        </div>
        <div class="mt-6">
          <p class="text-gray-500 text-xs mb-3">طرق الدفع</p>
          <div class="flex flex-wrap gap-2">
            {% for m in ['Mada', 'Visa', 'Apple Pay', 'STC Pay'] %}
              <span class="px-2.5 py-1 bg-gray-800 border border-gray-700 rounded text-gray-400 text-xs">{{ m }}</span>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>

    <div class="h-px bg-gray-800 mb-7"></div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <p>© {{ "now"|date("Y") }} {{ store.name }}. {{ trans('general.all_rights') }}.</p>
      <div class="flex items-center gap-4">
        <a href="{{ store.url }}/pages/privacy" class="hover:text-gold transition-colors">{{ trans('general.privacy_policy') }}</a>
        <span class="text-gray-700">|</span>
        <a href="{{ store.url }}/pages/terms" class="hover:text-gold transition-colors">{{ trans('general.terms') }}</a>
      </div>
    </div>
  </div>
</footer>
