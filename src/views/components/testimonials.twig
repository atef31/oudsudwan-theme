<section class="py-14 lg:py-20 bg-gray-50">
  <div class="max-w-screen-xl mx-auto px-4 lg:px-6">

    <div class="text-center mb-10">
      <p class="text-gold text-xs tracking-[0.3em] uppercase mb-2" style="font-family:'Cormorant Garamond',serif;">آراء عملائنا</p>
      <h2 class="text-2xl lg:text-3xl font-black text-gray-900">{{ trans('general.testimonials_title') }}</h2>
      <div class="w-10 h-0.5 bg-gold mx-auto mt-3"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {% for t in [
        {
          name: 'محمد العتيبي',
          city: 'الرياض',
          stars: 5,
          text: 'من أجود زيوت العود التي تذوقتها. الرائحة عميقة وأصيلة وتدوم طويلاً. سدوان للعود تستحق كل التقدير.'
        },
        {
          name: 'فيصل الشمري',
          city: 'جدة',
          stars: 5,
          text: 'شرائح العود الفيتنامي ممتازة جداً، الدخان كثيف والرائحة تملأ الغرفة. سأعيد الطلب حتماً.'
        },
        {
          name: 'عبدالله القحطاني',
          city: 'الدمام',
          stars: 5,
          text: 'التغليف فاخر جداً وجعل هديتي مميزة. خدمة العملاء سريعة الرد ومحترفة. شكراً سدوان.'
        }
      ] %}
        <div class="bg-white border border-gray-100 hover:border-gold/30 rounded-2xl p-7 transition-all duration-300 hover:shadow-card flex flex-col">
          {# Stars #}
          <div class="flex gap-0.5 mb-4">
            {% for i in 1..t.stars %}
              <svg class="w-4 h-4 text-gold" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            {% endfor %}
          </div>

          {# Quote #}
          <p class="text-gray-600 text-sm leading-relaxed flex-1 mb-6">"{{ t.text }}"</p>

          {# Author #}
          <div class="flex items-center gap-3 border-t border-gray-50 pt-5">
            <div class="w-10 h-10 rounded-full bg-gold/10 border border-gold/20 flex items-center justify-center text-gold font-black text-sm shrink-0">
              {{ t.name|slice(0, 1) }}
            </div>
            <div>
              <p class="text-gray-900 font-semibold text-sm">{{ t.name }}</p>
              <p class="text-gray-400 text-xs">{{ t.city }}</p>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
