<header id="site-header" class="sticky top-0 z-50 w-full bg-white border-b border-gray-100 shadow-sm transition-all duration-300" style="font-family: 'Tajawal', sans-serif;">

  {# Top info bar — desktop only #}
  <div class="hidden lg:block bg-gray-50 border-b border-gray-100">
    <div class="max-w-screen-xl2 mx-auto px-6 h-9 flex items-center justify-between text-xs text-gray-500">
      <div class="flex items-center gap-4">
        <a href="https://wa.me/{{ theme.settings.get('whatsapp_number', '966XXXXXXXXX')|default('966XXXXXXXXX') }}" target="_blank" rel="noopener" class="flex items-center gap-1.5 hover:text-gold transition-colors">
          <svg class="w-3.5 h-3.5 text-green-500" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a8.073 8.073 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479s1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.861 9.861 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
          <span dir="ltr">+{{ theme.settings.get('whatsapp_number', '966XXXXXXXXX')|default('966XXXXXXXXX') }}</span>
        </a>
        <span class="text-gray-300">|</span>
        <a href="mailto:{{ store.email|default('info@oudsudwan.com') }}" class="hover:text-gold transition-colors">{{ store.email|default('info@oudsudwan.com') }}</a>
      </div>
      <div class="flex items-center gap-1">
        <a href="{{ store.url }}/pages/our-story" class="px-2 hover:text-gold transition-colors">{{ trans('general.about') }}</a>
        <span class="text-gray-300">|</span>
        <a href="{{ store.url }}/pages/contact" class="px-2 hover:text-gold transition-colors">{{ trans('general.contact') }}</a>
        <span class="text-gray-300">|</span>
        <salla-user class="text-xs"></salla-user>
      </div>
    </div>
  </div>

  {# Main navbar #}
  <nav class="max-w-screen-xl2 mx-auto px-4 lg:px-6 h-16 lg:h-20 grid grid-cols-3 items-center gap-4">

    {# Left — navigation links #}
    <ul class="hidden lg:flex items-center gap-0 list-none m-0 p-0">
      <li class="relative group">
        <button class="flex items-center gap-1 px-4 py-2 text-gray-700 hover:text-gold text-sm font-medium transition-colors">
          {{ trans('general.collection') }}
          <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full start-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-52">
          <ul class="bg-white border border-gray-100 shadow-lg rounded-lg overflow-hidden list-none m-0 p-1">
            {% for item in [
              { label: trans('general.oud_oil'),   href: '/categories/oud-oil' },
              { label: trans('general.oud_chips'),  href: '/categories/oud-chips' },
              { label: trans('general.incense'),    href: '/categories/incense' },
              { label: trans('general.gift_sets'),  href: '/categories/gift-sets' }
            ] %}
              <li><a href="{{ store.url }}{{ item.href }}" class="flex items-center gap-2 px-4 py-2.5 text-gray-600 hover:text-gold hover:bg-gray-50 text-sm transition-colors rounded">
                <span class="w-1.5 h-1.5 rounded-full bg-gold/60"></span>{{ item.label }}
              </a></li>
            {% endfor %}
          </ul>
        </div>
      </li>
      <li><a href="{{ store.url }}/categories/best-sellers" class="block px-4 py-2 text-gray-700 hover:text-gold text-sm font-medium transition-colors">{{ trans('general.best_sellers') }}</a></li>
      <li><a href="{{ store.url }}/categories/gift-sets" class="block px-4 py-2 text-gray-700 hover:text-gold text-sm font-medium transition-colors">{{ trans('general.gift_sets') }}</a></li>
      <li><a href="{{ store.url }}/pages/our-story" class="block px-4 py-2 text-gray-700 hover:text-gold text-sm font-medium transition-colors">{{ trans('general.about') }}</a></li>
    </ul>

    {# Center — Logo #}
    <div class="flex justify-center">
      <a href="{{ store.url }}" class="group flex flex-col items-center">
        {% if store.logo %}
          <img src="{{ store.logo }}" alt="{{ store.name }}" class="h-10 w-auto object-contain" />
        {% else %}
          <span class="font-serif font-semibold text-gray-900 tracking-[0.2em] uppercase text-lg leading-none group-hover:text-gold transition-colors" style="font-family: 'Cormorant Garamond', serif;">OUDSUDWAN</span>
          <span class="text-gray-400 text-[10px] tracking-[0.15em] mt-0.5" style="font-family: 'Tajawal', sans-serif;">سدوان للعود</span>
        {% endif %}
      </a>
    </div>

    {# Right — actions #}
    <div class="flex items-center justify-end gap-1">
      {# Search #}
      <button id="search-toggle" aria-label="{{ trans('general.search') }}" class="w-9 h-9 flex items-center justify-center text-gray-600 hover:text-gold transition-colors rounded-full hover:bg-gray-50">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </button>

      {# Wishlist #}
      <button onclick="salla.wishlist.toggle()" aria-label="{{ trans('general.wishlist') }}" class="hidden sm:flex w-9 h-9 items-center justify-center text-gray-600 hover:text-gold transition-colors rounded-full hover:bg-gray-50">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      </button>

      {# Cart #}
      <button onclick="salla.cart.toggle()" aria-label="{{ trans('general.cart') }}" class="relative w-9 h-9 flex items-center justify-center text-gray-600 hover:text-gold transition-colors rounded-full hover:bg-gray-50">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        {% if cart.count > 0 %}
          <span class="absolute -top-0.5 -end-0.5 min-w-[18px] h-[18px] px-0.5 bg-gold text-white text-[10px] font-bold rounded-full flex items-center justify-center leading-none">{{ cart.count }}</span>
        {% endif %}
      </button>

      {# Mobile menu #}
      <button id="mobile-menu-toggle" aria-label="{{ trans('general.menu') }}" class="lg:hidden w-9 h-9 flex items-center justify-center text-gray-600 hover:text-gold transition-colors rounded-full hover:bg-gray-50">
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </nav>

  {# Search bar #}
  <div id="search-bar" class="hidden border-t border-gray-100 bg-white">
    <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6 py-3">
      <salla-search placeholder="{{ trans('general.search') }}..." class="w-full"></salla-search>
    </div>
  </div>

  {# Mobile menu #}
  <div id="mobile-menu" class="lg:hidden hidden fixed inset-0 z-40 bg-white overflow-y-auto" style="top: var(--header-h, 64px);">
    <nav class="px-6 py-6 flex flex-col divide-y divide-gray-100">
      <a href="{{ store.url }}" class="py-4 text-gray-800 font-medium hover:text-gold transition-colors">{{ trans('general.home') }}</a>

      <div class="py-4">
        <button id="mob-cat-toggle" class="w-full flex items-center justify-between text-gray-800 font-medium hover:text-gold transition-colors">
          {{ trans('general.collection') }}
          <svg id="mob-cat-arrow" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="mob-cat-sub" class="hidden mt-3 ps-4 space-y-2">
          <a href="{{ store.url }}/categories/oud-oil"    class="block py-1.5 text-gray-600 hover:text-gold transition-colors text-sm">{{ trans('general.oud_oil') }}</a>
          <a href="{{ store.url }}/categories/oud-chips"  class="block py-1.5 text-gray-600 hover:text-gold transition-colors text-sm">{{ trans('general.oud_chips') }}</a>
          <a href="{{ store.url }}/categories/incense"    class="block py-1.5 text-gray-600 hover:text-gold transition-colors text-sm">{{ trans('general.incense') }}</a>
          <a href="{{ store.url }}/categories/gift-sets"  class="block py-1.5 text-gray-600 hover:text-gold transition-colors text-sm">{{ trans('general.gift_sets') }}</a>
        </div>
      </div>

      <a href="{{ store.url }}/categories/best-sellers" class="py-4 text-gray-800 font-medium hover:text-gold transition-colors">{{ trans('general.best_sellers') }}</a>
      <a href="{{ store.url }}/categories/gift-sets"    class="py-4 text-gray-800 font-medium hover:text-gold transition-colors">{{ trans('general.gift_sets') }}</a>
      <a href="{{ store.url }}/pages/our-story"         class="py-4 text-gray-800 font-medium hover:text-gold transition-colors">{{ trans('general.about') }}</a>
      <a href="{{ store.url }}/pages/contact"           class="py-4 text-gray-800 font-medium hover:text-gold transition-colors">{{ trans('general.contact') }}</a>

      <div class="pt-6">
        <a href="https://wa.me/{{ theme.settings.get('whatsapp_number', '966XXXXXXXXX')|default('966XXXXXXXXX') }}" target="_blank" rel="noopener"
           class="flex items-center justify-center gap-2 w-full bg-green-500 text-white font-medium py-3 rounded-lg">
          {{ trans('general.whatsapp_cta') }}
        </a>
      </div>
    </nav>
  </div>

</header>
