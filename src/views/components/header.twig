<!-- OUDSUDWAN-HEADER-V2 -->
<header id="site-header" class="sticky top-0 z-90 w-full transition-all duration-300">

  {# ══════════════════════════════════════════════════
     TOP SECONDARY BAR  (mirrors Arabian Oud's top strip)
     Left : WhatsApp + Email
     Right: quick links — no language switcher
  ══════════════════════════════════════════════════ #}
  <div id="top-bar" class="bg-brand-gray border-b border-gold/10 hidden lg:block">
    <div class="max-w-screen-xl2 mx-auto px-4 lg:px-8 h-9 flex items-center justify-between">

      {# Left — contact info #}
      <div class="flex items-center gap-5">
        <a href="https://wa.me/{{ settings.whatsapp_number|default('966XXXXXXXXX') }}"
           target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-1.5 text-ivory/55 hover:text-gold transition-colors duration-200 text-xs">
          <svg class="w-3.5 h-3.5 text-green-400" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span dir="ltr">+{{ settings.whatsapp_number|default('966XXXXXXXXX') }}</span>
        </a>

        <span class="text-gold/20">|</span>

        <a href="mailto:{{ store.email|default('info@oudsudwan.com') }}"
           class="flex items-center gap-1.5 text-ivory/55 hover:text-gold transition-colors duration-200 text-xs">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          {{ store.email|default('info@oudsudwan.com') }}
        </a>
      </div>

      {# Right — quick nav links #}
      <div class="flex items-center gap-1">
        <a href="{{ store.url }}/pages/our-story"
           class="px-3 py-1 text-ivory/55 hover:text-gold transition-colors duration-200 text-xs">
          {{ 'من نحن' | trans }}
        </a>
        <span class="text-gold/20 text-xs">|</span>
        <a href="{{ store.url }}/pages/contact"
           class="px-3 py-1 text-ivory/55 hover:text-gold transition-colors duration-200 text-xs">
          {{ 'اتصل بنا' | trans }}
        </a>
        <span class="text-gold/20 text-xs">|</span>
        <a href="{{ store.url }}/categories/best-sellers"
           class="px-3 py-1 text-ivory/55 hover:text-gold transition-colors duration-200 text-xs">
          {{ 'الأكثر مبيعاً' | trans }}
        </a>
        <span class="text-gold/20 text-xs">|</span>
        {# User account shortcut #}
        <salla-user class="text-ivory/55 hover:text-gold transition-colors text-xs"></salla-user>
      </div>
    </div>
  </div>

  {# ══════════════════════════════════════════════════
     MAIN NAVBAR
     Logo centered · Nav left · Actions right
  ══════════════════════════════════════════════════ #}
  <div class="bg-black/97 backdrop-blur-md border-b border-gold/10">
    <nav class="max-w-screen-xl2 mx-auto px-4 lg:px-8 h-18 grid grid-cols-3 items-center gap-4">

      {# Col 1 — Desktop navigation (right side in RTL) #}
      <ul class="hidden lg:flex items-center gap-0 list-none m-0 p-0 justify-start">

        <li class="relative group">
          <button class="nav-link flex items-center gap-1 px-4 py-2 text-ivory/85 hover:text-gold font-tajawal font-medium text-sm tracking-wide transition-colors duration-200">
            {{ 'المجموعة' | trans }}
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          {# Mega dropdown #}
          <div class="absolute top-full start-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-52">
            <ul class="bg-brand-gray border border-gold/20 shadow-gold-lg overflow-hidden list-none m-0 p-1 rounded-b-lg">
              {% for item in [
                { label: 'زيت العود',       href: '/categories/oud-oil',   sub: 'Oud Oil' },
                { label: 'شرائح العود',     href: '/categories/oud-chips', sub: 'Oud Chips' },
                { label: 'البخور',          href: '/categories/incense',   sub: 'Incense' },
                { label: 'مجموعات الهدايا', href: '/categories/gift-sets', sub: 'Gift Sets' }
              ] %}
                <li>
                  <a href="{{ store.url }}{{ item.href }}"
                     class="flex items-center justify-between px-4 py-2.5 text-ivory/80 hover:text-gold hover:bg-black/60 transition-colors text-sm rounded group/item">
                    <span class="font-tajawal">{{ item.label }}</span>
                    <span class="font-cormorant text-gold/50 text-xs italic group-hover/item:text-gold/80 transition-colors">{{ item.sub }}</span>
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        </li>

        <li>
          <a href="{{ store.url }}/categories/best-sellers"
             class="nav-link block px-4 py-2 text-ivory/85 hover:text-gold font-tajawal font-medium text-sm tracking-wide transition-colors duration-200 relative after:absolute after:bottom-0 after:start-0 after:w-0 after:h-px after:bg-gold after:transition-all after:duration-300 hover:after:w-full">
            {{ 'الأكثر مبيعاً' | trans }}
          </a>
        </li>

        <li>
          <a href="{{ store.url }}/categories/gift-sets"
             class="nav-link block px-4 py-2 text-ivory/85 hover:text-gold font-tajawal font-medium text-sm tracking-wide transition-colors duration-200 relative after:absolute after:bottom-0 after:start-0 after:w-0 after:h-px after:bg-gold after:transition-all after:duration-300 hover:after:w-full">
            {{ 'مجموعات الهدايا' | trans }}
          </a>
        </li>
      </ul>

      {# Col 2 — Logo (centered) #}
      <div class="flex justify-center">
        <a href="{{ store.url }}" aria-label="{{ store.name }}" class="group flex flex-col items-center">
          {% if settings.logo %}
            <img src="{{ settings.logo }}" alt="{{ store.name }}" class="h-10 w-auto object-contain transition-opacity duration-300 group-hover:opacity-80" />
          {% else %}
            <span class="font-cormorant font-semibold text-gold tracking-[0.25em] uppercase text-xl leading-none group-hover:text-gold-light transition-colors duration-300">OUDSUDWAN</span>
            <span class="font-tajawal text-ivory/50 text-[10px] tracking-[0.2em] mt-0.5">سدوان للعود</span>
            <div class="w-full h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent mt-1 scale-x-0 group-hover:scale-x-100 transition-transform duration-300"></div>
          {% endif %}
        </a>
      </div>

      {# Col 3 — Right actions #}
      <div class="flex items-center gap-1 justify-end">

        {# Search #}
        <button id="search-toggle" aria-label="{{ 'بحث' | trans }}"
          class="w-9 h-9 flex items-center justify-center text-ivory/70 hover:text-gold transition-colors duration-200 rounded hover:bg-white/5">
          <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width:18px;height:18px;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </button>

        {# Wishlist #}
        <button aria-label="{{ 'المفضلة' | trans }}" onclick="salla.wishlist.open()"
          class="w-9 h-9 hidden sm:flex items-center justify-center text-ivory/70 hover:text-gold transition-colors duration-200 rounded hover:bg-white/5">
          <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </button>

        {# Cart #}
        <button aria-label="{{ 'السلة' | trans }}" onclick="salla.cart.toggle()"
          class="relative w-9 h-9 flex items-center justify-center text-ivory/70 hover:text-gold transition-colors duration-200 rounded hover:bg-white/5">
          <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          {% if cart.count > 0 %}
            <span class="absolute -top-0.5 -end-0.5 min-w-4 h-4 px-0.5 bg-gold text-black text-[10px] font-black rounded-full flex items-center justify-center leading-none">
              {{ cart.count }}
            </span>
          {% endif %}
        </button>

        {# Mobile hamburger #}
        <button id="mobile-menu-toggle" aria-label="{{ 'القائمة' | trans }}" aria-expanded="false"
          class="lg:hidden w-9 h-9 flex items-center justify-center text-ivory/70 hover:text-gold transition-colors duration-200 rounded hover:bg-white/5 ms-1">
          <span id="icon-burger" class="flex flex-col gap-1.5">
            <span class="w-5 h-px bg-current block transition-all duration-300"></span>
            <span class="w-3.5 h-px bg-current block transition-all duration-300"></span>
            <span class="w-5 h-px bg-current block transition-all duration-300"></span>
          </span>
          <svg id="icon-close" class="hidden" style="width:20px;height:20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </nav>

    {# Search slide-down #}
    <div id="search-bar" class="hidden border-t border-gold/10">
      <div class="max-w-screen-xl2 mx-auto px-4 lg:px-8 py-3">
        <salla-search placeholder="{{ 'ابحث عن منتج...' | trans }}" class="w-full"></salla-search>
      </div>
    </div>
  </div>

  {# ══════════════════════════════════════════════════
     MOBILE FULL-SCREEN MENU
  ══════════════════════════════════════════════════ #}
  <div id="mobile-menu"
    class="lg:hidden hidden fixed inset-0 z-80 bg-black overflow-y-auto"
    style="top: calc(var(--header-height, 72px));">

    {# Mobile top contact strip #}
    <div class="bg-brand-gray border-b border-gold/10 px-6 py-3 flex items-center justify-between">
      <a href="https://wa.me/{{ settings.whatsapp_number|default('966XXXXXXXXX') }}"
         class="flex items-center gap-2 text-green-400 text-xs">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span dir="ltr">+{{ settings.whatsapp_number|default('966XXXXXXXXX') }}</span>
      </a>
      <salla-user></salla-user>
    </div>

    <nav class="px-6 py-6 flex flex-col">

      <a href="{{ store.url }}"
         class="flex items-center justify-between py-4 border-b border-gold/10 text-ivory font-tajawal font-medium text-lg hover:text-gold transition-colors">
        {{ 'الرئيسية' | trans }}
        <svg class="w-4 h-4 text-gold/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
        </svg>
      </a>

      {# Collection accordion #}
      <div class="border-b border-gold/10">
        <button id="mobile-collection-toggle"
          class="w-full flex items-center justify-between py-4 text-ivory font-tajawal font-medium text-lg hover:text-gold transition-colors">
          {{ 'المجموعة' | trans }}
          <svg id="mobile-collection-arrow" class="w-4 h-4 text-gold/60 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div id="mobile-collection-submenu" class="hidden ps-4 pb-4 space-y-1">
          {% for item in [
            { label: 'زيت العود',       href: '/categories/oud-oil' },
            { label: 'شرائح العود',     href: '/categories/oud-chips' },
            { label: 'البخور',          href: '/categories/incense' },
            { label: 'مجموعات الهدايا', href: '/categories/gift-sets' }
          ] %}
            <a href="{{ store.url }}{{ item.href }}"
               class="flex items-center gap-2 py-2.5 text-ivory/65 hover:text-gold transition-colors text-base">
              <span class="w-1 h-1 rounded-full bg-gold/60"></span>
              {{ item.label | trans }}
            </a>
          {% endfor %}
        </div>
      </div>

      {% for item in [
        { label: 'الأكثر مبيعاً',    href: '/categories/best-sellers' },
        { label: 'مجموعات الهدايا',  href: '/categories/gift-sets' },
        { label: 'قصتنا',            href: '/pages/our-story' },
        { label: 'اتصل بنا',         href: '/pages/contact' }
      ] %}
        <a href="{{ store.url }}{{ item.href }}"
           class="flex items-center justify-between py-4 border-b border-gold/10 text-ivory font-tajawal font-medium text-lg hover:text-gold transition-colors">
          {{ item.label | trans }}
          <svg class="w-4 h-4 text-gold/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
          </svg>
        </a>
      {% endfor %}

      {# Mobile CTA #}
      <a href="https://wa.me/{{ settings.whatsapp_number|default('966XXXXXXXXX') }}"
         target="_blank" rel="noopener noreferrer"
         class="mt-8 flex items-center justify-center gap-2 bg-green-500 text-white font-tajawal font-bold py-3.5 rounded-lg">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        {{ 'تواصل مع خبير العود' | trans }}
      </a>
    </nav>
  </div>

</header>
