<section class="py-14 lg:py-20 bg-gray-50" style="font-family: 'Tajawal', sans-serif;">
  <div class="max-w-screen-xl2 mx-auto px-4 lg:px-6">

    <div class="text-center mb-10">
      <p class="text-gold text-sm tracking-[0.25em] uppercase mb-2" style="font-family: 'Cormorant Garamond', serif;">OUDSUDWAN</p>
      <h2 class="text-2xl lg:text-3xl font-black text-gray-900 mb-3">{{ trans('general.categories_title') }}</h2>
      <div class="w-12 h-0.5 bg-gold mx-auto"></div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {% set default_cats = [
        { name: trans('general.oud_oil'),   slug: 'oud-oil',   from: '195' },
        { name: trans('general.oud_chips'), slug: 'oud-chips', from: '120' },
        { name: trans('general.incense'),   slug: 'incense',   from: '95'  },
        { name: trans('general.gift_sets'), slug: 'gift-sets', from: '175' }
      ] %}

      {% if store.categories is defined and store.categories|length > 0 %}
        {% for cat in store.categories|slice(0,4) %}
          <a href="{{ cat.url }}" class="group relative overflow-hidden rounded-xl aspect-[3/4] flex flex-col justify-end bg-gray-200 border border-gray-200 hover:border-gold/40 transition-all duration-400">
            {% if cat.image.url %}<img src="{{ cat.image.url }}" alt="{{ cat.name }}" loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />{% endif %}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 h-0.5 bg-gold scale-x-0 group-hover:scale-x-100 transition-transform duration-400 origin-start"></div>
            <div class="relative z-10 p-4">
              <h3 class="text-white font-bold text-base mb-1">{{ cat.name }}</h3>
              <span class="text-gold text-sm">{{ trans('general.explore') }} ←</span>
            </div>
          </a>
        {% endfor %}
      {% else %}
        {% for cat in default_cats %}
          <a href="{{ store.url }}/categories/{{ cat.slug }}" class="group relative overflow-hidden rounded-xl aspect-[3/4] flex flex-col justify-end bg-dark-brown border border-transparent hover:border-gold/40 transition-all duration-400">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 h-0.5 bg-gold scale-x-0 group-hover:scale-x-100 transition-transform duration-400 origin-start"></div>
            <div class="relative z-10 p-4">
              <h3 class="text-white font-bold text-base mb-0.5">{{ cat.name }}</h3>
              <p class="text-gold text-xs">{{ trans('general.from_price') }} {{ cat.from }} {{ trans('general.sar') }}</p>
            </div>
          </a>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
