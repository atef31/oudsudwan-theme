<section id="hero-slider" class="relative w-full overflow-hidden bg-gray-900" style="height: clamp(480px, 80vh, 820px);">

  <div id="slides-track" class="flex h-full transition-transform duration-700 ease-in-out">
    {% set slides = [
      { image: theme.settings.get('hero_slide_1_image', ''), title: theme.settings.get('hero_slide_1_title', '')|default('عود فيتنامي أصيل'), sub: 'Authentic Vietnamese Oud', href: store.url ~ '/categories' },
      { image: theme.settings.get('hero_slide_2_image', ''), title: theme.settings.get('hero_slide_2_title', '')|default('زيوت العود الفاخرة'), sub: 'Premium Oud Oils Collection', href: store.url ~ '/categories/oud-oil' },
      { image: theme.settings.get('hero_slide_3_image', ''), title: theme.settings.get('hero_slide_3_title', '')|default('مجموعات الهدايا الملكية'), sub: 'Royal Gift Collections', href: store.url ~ '/categories/gift-sets' }
    ] %}

    {% for slide in slides %}
      <div class="slide w-full h-full shrink-0 relative">
        {% if slide.image %}
          <img src="{{ slide.image }}" alt="{{ slide.title }}" class="absolute inset-0 w-full h-full object-cover object-center" loading="{{ loop.first ? 'eager' : 'lazy' }}" />
        {% else %}
          <div class="absolute inset-0 bg-gradient-to-br from-dark-brown via-gray-900 to-black"></div>
        {% endif %}
        <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 55%, transparent 100%);"></div>

        <div class="relative z-10 h-full max-w-screen-xl2 mx-auto px-6 lg:px-16 flex items-center">
          <div class="max-w-xl" style="font-family: 'Tajawal', sans-serif;">
            <p class="text-gold/80 text-sm tracking-[0.3em] uppercase mb-4" style="font-family: 'Cormorant Garamond', serif;">{{ slide.sub }}</p>
            <div class="w-12 h-px bg-gold mb-5"></div>
            <h2 class="text-white font-black mb-5 leading-tight" style="font-size: clamp(2.2rem, 5vw, 4rem);">{{ slide.title }}</h2>
            <div class="flex gap-3 flex-wrap">
              <a href="{{ slide.href }}" class="inline-flex items-center gap-2 bg-gold hover:bg-gold-dark text-black font-bold px-7 py-3.5 rounded transition-all duration-300 shadow-gold hover:shadow-gold-lg">
                {{ trans('general.shop_now') }}
              </a>
              <a href="{{ store.url }}/categories" class="inline-flex items-center gap-2 border border-white/40 text-white hover:border-gold hover:text-gold px-6 py-3.5 rounded transition-all duration-300">
                {{ trans('general.explore') }}
              </a>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  {# Arrows #}
  <button id="slide-prev" aria-label="السابق" class="absolute start-4 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full bg-white/20 backdrop-blur-sm text-white hover:bg-gold hover:text-black transition-all flex items-center justify-center">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <button id="slide-next" aria-label="التالي" class="absolute end-4 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full bg-white/20 backdrop-blur-sm text-white hover:bg-gold hover:text-black transition-all flex items-center justify-center">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  </button>

  {# Dots #}
  <div class="absolute bottom-6 start-1/2 -translate-x-1/2 z-20 flex gap-2">
    {% for i in 0..2 %}
      <button class="hero-dot w-2.5 h-2.5 rounded-full border border-white/60 transition-all {{ i == 0 ? 'bg-gold border-gold scale-110' : 'bg-transparent' }}" data-idx="{{ i }}"></button>
    {% endfor %}
  </div>

  <script>
  (function(){
    var track=document.getElementById('slides-track'), dots=document.querySelectorAll('.hero-dot'), cur=0, n=3, t;
    function go(i){cur=(i+n)%n;track.style.transform='translateX('+(document.dir==='rtl'?'':'-')+cur*100+'%)';dots.forEach(function(d,j){d.classList.toggle('bg-gold',j===cur);d.classList.toggle('border-gold',j===cur);d.classList.toggle('scale-110',j===cur);d.classList.toggle('bg-transparent',j!==cur);});}
    function reset(){clearInterval(t);t=setInterval(function(){go(cur+1);},5000);}
    document.getElementById('slide-next').onclick=function(){go(cur+1);reset();};
    document.getElementById('slide-prev').onclick=function(){go(cur-1);reset();};
    dots.forEach(function(d){d.onclick=function(){go(+d.dataset.idx);reset();};});
    reset();
  })();
  </script>
</section>
