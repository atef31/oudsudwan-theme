{
  "name": "oudsudwan-theme",
  "version": "1.0.0",
  "description": "OUDSUDWAN — Luxury Oud eCommerce Salla Twilight Theme",
  "private": true,
  "scripts": {
    "build": "npx tailwindcss -i ./src/assets/css/app.css -o ./dist/css/app.css --minify && node -e \"require('fs').mkdirSync('dist/js',{recursive:true});require('fs').copyFileSync('src/assets/js/app.js','dist/js/app.js')\"",
    "development": "npx tailwindcss -i ./src/assets/css/app.css -o ./dist/css/app.css --watch",
    "watch": "npx tailwindcss -i ./src/assets/css/app.css -o ./dist/css/app.css --watch",
    "dev": "npx tailwindcss -i ./src/assets/css/app.css -o ./dist/css/app.css --watch",
    "preview": "node preview/serve.js"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.17",
    "express": "^5.2.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "twig": "^3.0.0"
  }
}
