# Force LF line endings and UTF-8 for all text files
* text=auto eol=lf
*.json text eol=lf encoding=utf-8
*.twig text eol=lf encoding=utf-8
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf
# Binary files — no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
